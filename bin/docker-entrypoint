#!/bin/bash -e

# If running the rails server then create or migrate existing database.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # Prepare all databases: creates if missing, loads schema, runs migrations.
  ./bin/rails db:prepare

  # Ensure Solid Queue/Cache/Cable schemas are loaded.
  # db:prepare may not load schemas for secondary databases that use
  # standalone schema files instead of migrations.
  ./bin/rails db:schema:load:queue || true
  ./bin/rails db:schema:load:cache || true
  ./bin/rails db:schema:load:cable || true
fi

exec "${@}"
