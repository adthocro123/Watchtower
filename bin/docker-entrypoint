#!/bin/bash -e

# If running the rails server then create or migrate existing database.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # Prepare the primary database (create + migrate).
  ./bin/rails db:prepare

  # Load Solid Queue/Cache/Cable schemas into their databases.
  # The app uses config.active_record.schema_format = :sql globally, which
  # causes db:prepare to try psql on the Ruby schema files. We load them
  # directly via Rails runner instead.
  ./bin/rails runner '
    { queue: :solid_queue_jobs, cache: :solid_cache_entries, cable: :solid_cable_messages }.each do |db_name, check_table|
      begin
        config = ActiveRecord::Base.configurations.configs_for(env_name: Rails.env, name: db_name.to_s)
        next unless config
        ActiveRecord::Base.establish_connection(config)
        unless ActiveRecord::Base.connection.table_exists?(check_table)
          schema = Rails.root.join("db", "#{db_name}_schema.rb")
          load(schema) if schema.exist?
          puts "Loaded schema for #{db_name}"
        else
          puts "Schema for #{db_name} already loaded"
        end
      rescue => e
        puts "Warning: #{db_name} schema: #{e.message}"
      end
    end
    ActiveRecord::Base.establish_connection(:primary)
  ' || true

  # Ensure the materialized view is populated (required on first deploy).
  ./bin/rails runner 'TeamEventSummary.refresh!' || true
fi

exec "${@}"
