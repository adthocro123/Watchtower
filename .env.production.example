# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production to git!

# Rails master key (from config/master.key)
RAILS_MASTER_KEY=

# PostgreSQL password for the lighthouse user
LIGHTHOUSE_DATABASE_PASSWORD=

# The Blue Alliance API key
TBA_API_KEY=

# Web Push (PWA notifications)
# Generate VAPID keys and set these in deployment secrets.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@example.com
