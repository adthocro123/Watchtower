<% content_for(:title) { "Compare Teams - Watchtower" } %>

<div class="max-w-6xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">Team Comparison</h1>
    <p class="text-sm text-gray-400 mt-1">Compare performance at <%= current_event.name %></p>
  </div>

  <% # Team selector %>
  <%= form_with url: team_comparison_path, method: :get, class: "mb-6", data: { turbo_action: "replace" } do |f| %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <label class="block text-xs text-gray-500 uppercase tracking-wider mb-2">Select teams to compare (up to 6)</label>
      <div class="flex flex-wrap gap-2 mb-3">
        <% @all_teams.each do |team| %>
          <% selected = @teams.include?(team) %>
          <label class="flex items-center gap-1 px-3 py-1.5 rounded-lg border cursor-pointer transition text-sm
            bg-gray-800 border-gray-700 text-gray-400 hover:border-gray-600
            has-[:checked]:bg-orange-500/20 has-[:checked]:border-orange-500/30 has-[:checked]:text-orange-400">
            <input type="checkbox" name="team_ids[]" value="<%= team.id %>" <%= 'checked' if selected %> class="hidden" onchange="this.form.submit()">
            <span class="font-bold"><%= team.team_number %></span>
          </label>
        <% end %>
      </div>
      <noscript>
        <button type="submit" class="px-4 py-2 bg-orange-600 hover:bg-orange-500 text-white text-sm font-medium rounded-lg transition">Compare</button>
      </noscript>
    </div>
  <% end %>

  <% if @teams.any? %>
    <%# ===== RADAR CHART ===== %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-6 mb-6"
         data-controller="radar-chart"
         data-radar-chart-teams-value="<%= @radar_teams.to_json %>"
         data-radar-chart-all-values-value="<%= @radar_all_values.to_json %>">
      <h3 class="text-lg font-semibold text-white mb-4">Performance Radar</h3>
      <div class="max-w-2xl mx-auto">
        <canvas></canvas>
      </div>
      <p class="text-xs text-gray-600 text-center mt-3">Normalized to best/worst at this event</p>
    </div>

    <%# ===== PERFORMANCE OVER TIME CHART ===== %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-6 mb-6"
         data-controller="stat-chart"
         data-stat-chart-all-data-value="<%= @line_chart_data.to_json %>">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-white">Performance Over Matches</h3>
        <select data-stat-chart-target="select"
                data-action="change->stat-chart#changeStat"
                class="bg-gray-800 border border-gray-700 text-gray-300 text-sm rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500">
          <% @line_chart_stats.each do |key, label| %>
            <option value="<%= key %>"><%= label %></option>
          <% end %>
        </select>
      </div>
      <canvas data-stat-chart-target="canvas"></canvas>
    </div>

    <%# ===== PIT SCOUTING COMPARISON ===== %>
    <% pit_entries = @teams.select { |t| @pit_data[t.id].present? } %>
    <% if pit_entries.any? %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
          <h3 class="text-lg font-semibold text-white">Pit Scouting Comparison</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-gray-500 text-xs uppercase tracking-wider border-b border-gray-800">
                <th class="px-4 py-3 text-left">Attribute</th>
                <% @teams.each do |team| %>
                  <th class="px-4 py-3 text-center"><%= team.team_number %></th>
                <% end %>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
              <% %w[drivetrain robot_width robot_length robot_height robot_weight].each do |attr| %>
                <tr class="hover:bg-gray-800/50">
                  <td class="px-4 py-3 text-gray-400"><%= attr.humanize %></td>
                  <% @teams.each do |team| %>
                    <% pit = @pit_data[team.id] %>
                    <td class="px-4 py-3 text-center font-mono text-white"><%= pit&.data&.dig(attr) || "—" %></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16 bg-gray-900 border border-gray-800 rounded-xl">
      <p class="text-gray-500">Select teams above to start comparing.</p>
    </div>
  <% end %>
</div>
