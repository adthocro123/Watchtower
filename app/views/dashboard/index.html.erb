<% content_for(:title) { "Dashboard - ScoutRail" } %>

<% if current_event %>
  <%# Event Header %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white"><%= @event.name %></h1>
    <p class="text-sm text-gray-400 mt-1">
      <%= @event.start_date&.strftime("%b %d") %> - <%= @event.end_date&.strftime("%b %d, %Y") %>
      <% if @event.city.present? %>
        &middot; <%= [@event.city, @event.state_prov].compact.join(", ") %>
      <% end %>
    </p>
  </div>

  <%# Stat Cards %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <%# Teams Scouted %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-8 h-8 bg-emerald-500/20 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Teams Scouted</span>
      </div>
      <p class="text-3xl font-bold text-white"><%= @team_summaries.count %></p>
    </div>

    <%# Entries %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-8 h-8 bg-blue-500/20 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Entries</span>
      </div>
      <p class="text-3xl font-bold text-white"><%= @recent_entries.unscope(:limit).count %></p>
    </div>

    <%# Avg Accuracy %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Avg Accuracy</span>
      </div>
      <% avg_accuracy = @team_summaries.any? ? (@team_summaries.average(:fuel_accuracy_pct) || 0).round(1) : 0 %>
      <p class="text-3xl font-bold text-white"><%= avg_accuracy %>%</p>
    </div>

    <%# Conflicts %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-8 h-8 bg-red-500/20 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.27 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
        </div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Conflicts</span>
      </div>
      <p class="text-3xl font-bold text-white"><%= @unresolved_conflicts_count %></p>
      <% if @unresolved_conflicts_count > 0 %>
        <%= link_to "Resolve", data_conflicts_path, class: "text-xs text-red-400 hover:text-red-300 transition" %>
      <% end %>
    </div>
  </div>

  <%# Top Teams Chart %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-6 mb-6">
    <h2 class="text-lg font-semibold text-white mb-4">Top 10 Teams by Avg Points</h2>
    <% top_teams_data = @team_summaries.limit(10).includes(:frc_team).each_with_object({}) do |s, hash|
      hash["##{s.frc_team.team_number}"] = s.avg_total_points.to_f.round(1)
    end %>
    <%= bar_chart top_teams_data,
                  colors: ["#10b981"],
                  library: {
                    scales: {
                      x: { ticks: { color: "#9ca3af" }, grid: { color: "#1f2937" } },
                      y: { ticks: { color: "#9ca3af" }, grid: { color: "#1f2937" } }
                    },
                    plugins: { legend: { display: false } }
                  } %>
  </div>

  <%# Top Teams Table %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Team Rankings</h2>
      <%= link_to "View All", teams_path, class: "text-sm text-emerald-400 hover:text-emerald-300 transition" %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-gray-500 text-xs uppercase tracking-wider border-b border-gray-800">
            <th class="px-4 py-3 text-left">#</th>
            <th class="px-4 py-3 text-left">Team</th>
            <th class="px-4 py-3 text-right hidden sm:table-cell">Avg Pts</th>
            <th class="px-4 py-3 text-right hidden sm:table-cell">Accuracy</th>
            <th class="px-4 py-3 text-right hidden md:table-cell">Avg Climb</th>
            <th class="px-4 py-3 text-right">Scouted</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800/50">
          <% @team_summaries.limit(15).includes(:frc_team).each_with_index do |summary, idx| %>
            <tr class="hover:bg-gray-800/50 transition">
              <td class="px-4 py-3 text-gray-400 font-mono"><%= idx + 1 %></td>
              <td class="px-4 py-3">
                <%= link_to team_path(summary.frc_team), class: "hover:text-emerald-400 transition" do %>
                  <span class="font-semibold text-white"><%= summary.frc_team.team_number %></span>
                  <span class="text-gray-400 text-xs ml-1 hidden sm:inline"><%= summary.frc_team.nickname %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right font-mono text-emerald-400 hidden sm:table-cell"><%= summary.avg_total_points.to_f.round(1) %></td>
              <td class="px-4 py-3 text-right hidden sm:table-cell">
                <div class="flex items-center justify-end gap-2">
                  <div class="w-16 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-500 rounded-full" style="width: <%= summary.fuel_accuracy_pct.to_f.round(0) %>%"></div>
                  </div>
                  <span class="text-xs font-mono text-gray-400"><%= summary.fuel_accuracy_pct.to_f.round(0) %>%</span>
                </div>
              </td>
              <td class="px-4 py-3 text-right font-mono text-gray-300 hidden md:table-cell"><%= summary.avg_climb_points.to_f.round(1) %></td>
              <td class="px-4 py-3 text-right font-mono text-gray-400"><%= summary.matches_scouted %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Recent Entries %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Recent Entries</h2>
      <%= link_to "View All", scouting_entries_path, class: "text-sm text-emerald-400 hover:text-emerald-300 transition" %>
    </div>
    <div class="divide-y divide-gray-800/50">
      <% @recent_entries.includes(:user, :frc_team, :match).each do |entry| %>
        <%= link_to scouting_entry_path(entry), class: "flex items-center justify-between px-4 sm:px-6 py-3 hover:bg-gray-800/50 transition" do %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center">
              <span class="text-sm font-bold text-emerald-400"><%= entry.frc_team.team_number %></span>
            </div>
            <div>
              <p class="text-sm font-medium text-white">
                Team <%= entry.frc_team.team_number %>
                <% if entry.match %>
                  <span class="text-gray-500">&middot;</span>
                  <span class="text-gray-400"><%= entry.match.display_name %></span>
                <% end %>
              </p>
              <p class="text-xs text-gray-500"><%= entry.user.full_name %> &middot; <%= time_ago_in_words(entry.created_at) %> ago</p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-sm font-bold text-white"><%= entry.total_points %> pts</p>
            <span class="text-xs px-1.5 py-0.5 rounded-full
              <%= case entry.status
                  when 'submitted' then 'bg-emerald-500/20 text-emerald-400'
                  when 'flagged' then 'bg-amber-500/20 text-amber-400'
                  when 'rejected' then 'bg-red-500/20 text-red-400'
                  end %>">
              <%= entry.status.capitalize %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

<% else %>
  <%# No Event Selected — Show Event Selector %>
  <div class="max-w-2xl mx-auto mt-8">
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-emerald-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white mb-2">Welcome to ScoutRail</h1>
      <p class="text-gray-400">Select an event to start scouting</p>
    </div>

    <div class="space-y-3">
      <% @events.each do |event| %>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 flex items-center justify-between hover:border-gray-700 transition">
          <div>
            <h3 class="font-semibold text-white"><%= event.name %></h3>
            <p class="text-sm text-gray-400">
              <%= event.start_date&.strftime("%b %d") %> - <%= event.end_date&.strftime("%b %d, %Y") %>
              <% if event.city.present? %>
                &middot; <%= [event.city, event.state_prov].compact.join(", ") %>
              <% end %>
            </p>
          </div>
          <%= button_to "Select", select_event_path(event), method: :post, class: "px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" %>
        </div>
      <% end %>

      <% if @events.empty? %>
        <div class="text-center py-12 text-gray-500">
          <p>No events found for the current year.</p>
          <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
            <%= link_to "Create Event", new_event_path, class: "inline-block mt-4 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
