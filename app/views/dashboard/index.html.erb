<% content_for(:title) { "Dashboard - Lighthouse" } %>

<%# Event Header %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white"><%= @event.name %></h1>
    <p class="text-sm text-gray-400 mt-1">
      <%= @event.start_date&.strftime("%b %d") %> - <%= @event.end_date&.strftime("%b %d, %Y") %>
      <% if @event.city.present? %>
        &middot; <%= [@event.city, @event.state_prov].compact.join(", ") %>
      <% end %>
    </p>
  </div>

  <%# Stat Cards %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <%# Teams Scouted %>
    <div class="stat-card group">
      <div class="flex items-center gap-2 mb-2">
        <div class="stat-card-icon bg-orange-500/20">
          <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Teams Scouted</span>
      </div>
      <p class="text-3xl font-bold text-white font-mono"><%= @team_summaries.count %></p>
    </div>

    <%# Entries %>
    <div class="stat-card group">
      <div class="flex items-center gap-2 mb-2">
        <div class="stat-card-icon bg-blue-500/20">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Entries</span>
      </div>
      <p class="text-3xl font-bold text-white font-mono"><%= @recent_entries.unscope(:limit).count %></p>
    </div>

    <%# Avg Accuracy %>
    <div class="stat-card group">
      <div class="flex items-center gap-2 mb-2">
        <div class="stat-card-icon bg-amber-500/20">
          <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Avg Accuracy</span>
      </div>
      <% avg_accuracy = @team_summaries.any? ? (@team_summaries.average(:fuel_accuracy_pct) || 0).round(1) : 0 %>
      <p class="text-3xl font-bold text-white font-mono"><%= avg_accuracy %>%</p>
    </div>

    <%# Conflicts %>
    <div class="stat-card group">
      <div class="flex items-center gap-2 mb-2">
        <div class="stat-card-icon bg-red-500/20">
          <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.27 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
        </div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Conflicts</span>
      </div>
      <div class="flex items-baseline gap-2">
        <p class="text-3xl font-bold text-white font-mono"><%= @unresolved_conflicts_count %></p>
        <% if @unresolved_conflicts_count > 0 %>
          <%= link_to "Resolve", data_conflicts_path, class: "text-xs text-red-400 hover:text-red-300 transition-colors duration-150 font-medium hover:underline" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Pit Scouting Progress + Quick Links %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <%# Pit Scouting Progress %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-white uppercase tracking-wider">Pit Scouting Progress</h2>
        <%= link_to "View All", pit_scouting_entries_path, class: "text-xs text-orange-400 hover:text-orange-300 transition" %>
      </div>
      <% pit_pct = @total_teams_at_event > 0 ? (@pit_scouted_count.to_f / @total_teams_at_event * 100).round(0) : 0 %>
      <div class="flex items-end gap-3 mb-3">
        <p class="text-4xl font-bold text-white"><%= @pit_scouted_count %></p>
        <p class="text-sm text-gray-500 pb-1">/ <%= @total_teams_at_event %> teams</p>
      </div>
      <div class="w-full h-3 bg-gray-800 rounded-full overflow-hidden mb-2">
        <div class="h-full rounded-full transition-all duration-500 <%= pit_pct == 100 ? 'bg-orange-500' : 'bg-amber-500' %>" style="width: <%= pit_pct %>%"></div>
      </div>
      <p class="text-xs text-gray-500"><%= pit_pct %>% complete &middot; <%= @total_teams_at_event - @pit_scouted_count %> remaining</p>
    </div>

    <%# Quick Links %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-5">
      <h2 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Quick Actions</h2>
      <div class="grid grid-cols-2 gap-2">
        <%= link_to new_scouting_entry_path, class: "flex items-center gap-2 px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group" do %>
          <div class="w-7 h-7 bg-orange-500/20 rounded-md flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <span class="text-sm text-gray-300 group-hover:text-white transition">Scout Match</span>
        <% end %>
        <%= link_to new_pit_scouting_entry_path, class: "flex items-center gap-2 px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group" do %>
          <div class="w-7 h-7 bg-blue-500/20 rounded-md flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <span class="text-sm text-gray-300 group-hover:text-white transition">Pit Scout</span>
        <% end %>
        <%= link_to new_match_simulator_path, class: "flex items-center gap-2 px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group" do %>
          <div class="w-7 h-7 bg-purple-500/20 rounded-md flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-sm text-gray-300 group-hover:text-white transition">Simulate</span>
        <% end %>
        <%= link_to predictions_path, class: "flex items-center gap-2 px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group" do %>
          <div class="w-7 h-7 bg-amber-500/20 rounded-md flex items-center justify-center shrink-0">
            <svg class="w-3.5 h-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <span class="text-sm text-gray-300 group-hover:text-white transition">Predictions (<%= @predictions_count %>)</span>
        <% end %>
      </div>

      <%# Offline cache (auto-prefetch + manual button) %>
      <div class="mt-3 pt-3 border-t border-gray-800" data-controller="prefetch" data-prefetch-event-id-value="<%= @event.id %>" data-prefetch-manifest-url-value="<%= offline_manifest_event_path(@event) %>">
        <button data-action="prefetch#cache"
                data-prefetch-target="cacheButton"
                class="flex items-center justify-center gap-2 w-full px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group text-sm text-gray-300 hover:text-white disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span>Cache for Offline</span>
        </button>
        <%# Inline progress bar %>
        <div data-prefetch-target="progressContainer" class="hidden mt-2">
          <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
            <div data-prefetch-target="progressBar"
                 class="bg-cyan-500 h-1.5 rounded-full transition-all duration-300"
                 style="width: 0%"></div>
          </div>
          <span data-prefetch-target="progressText" class="text-[10px] text-gray-500 mt-1 block text-center"></span>
        </div>
      </div>
    </div>
  </div>

  <%# Scout Accuracy Leaderboard %>
  <% if @scout_accuracy.any? %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-6 mb-6">
      <h2 class="text-lg font-semibold text-white mb-4">Scout Accuracy Leaderboard</h2>
      <div class="space-y-2">
        <% best_error = @scout_accuracy.filter_map { |r| r[:average_error] }.min %>
        <% worst_error = @scout_accuracy.filter_map { |r| r[:average_error] }.max %>
        <% @scout_accuracy.first(10).each_with_index do |result, idx| %>
          <% scout = result[:user] %>
          <% next unless scout %>
          <div class="flex items-center gap-3">
            <div class="w-6 text-center">
              <span class="text-xs font-bold text-gray-500 font-mono"><%= idx + 1 %></span>
            </div>
            <div class="w-8 h-8 bg-gray-800 rounded-full flex items-center justify-center">
              <span class="text-xs font-bold text-orange-400"><%= scout.first_name[0] %><%= scout.last_name[0] %></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate"><%= scout.full_name %></p>
            </div>
            <div class="flex items-center gap-2">
              <% if result[:average_error] %>
                <% bar_pct = worst_error > 0 ? ((1.0 - (result[:average_error] / worst_error)) * 100).round(0) : 100 %>
                <% bar_pct = [bar_pct, 10].max %>
                <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full rounded-full <%= result[:average_error] <= 5 ? 'bg-green-500' : result[:average_error] <= 15 ? 'bg-amber-500' : 'bg-red-500' %>" style="width: <%= bar_pct %>%"></div>
                </div>
                <span class="text-sm font-mono text-gray-400 w-24 text-right">~<%= result[:average_error] %> pts off</span>
              <% else %>
                <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
                  <div class="h-full bg-gray-700 rounded-full" style="width: 0%"></div>
                </div>
                <span class="text-sm font-mono text-gray-500 w-24 text-right">No data</span>
              <% end %>
              <span class="text-xs font-mono text-gray-600 w-6 text-right"><%= result[:total_entry_count] %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Scoring Distribution %>
  <% if @scoring_data.any? %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 sm:p-6 mb-6">
      <h2 class="text-lg font-semibold text-white mb-4">Scoring Distribution</h2>
      <% bins = Hash.new(0)
         @scoring_data.each { |score| bins["#{(score / 10).to_i * 10}-#{(score / 10).to_i * 10 + 9}"] += 1 }
         sorted_bins = bins.sort_by { |range, _| range.split("-").first.to_i }.to_h %>
      <%= column_chart sorted_bins,
                       colors: ["#f97316"],
                       xtitle: "Points Range",
                       ytitle: "Teams",
                       library: {
                         scales: {
                           x: { ticks: { color: "#9ca3af" }, grid: { color: "#1f2937" } },
                           y: { ticks: { color: "#9ca3af", stepSize: 1 }, grid: { color: "#1f2937" }, beginAtZero: true }
                         },
                         plugins: { legend: { display: false } }
                       } %>
    </div>
  <% end %>

  <%# Top Teams Chart %>
  <div class="scout-card p-4 sm:p-6 mb-6">
    <h2 class="text-lg font-semibold text-white mb-4">Top 10 Teams by Avg Points</h2>
    <% top_teams_data = @team_summaries.limit(10).includes(:frc_team).each_with_object({}) do |s, hash|
      hash["##{s.frc_team.team_number}"] = s.avg_total_points.to_f.round(1)
    end %>
    <% if top_teams_data.any? %>
      <div aria-label="Bar chart showing top 10 teams by average points scored">
        <%= bar_chart top_teams_data,
                      colors: ["#f97316"],
                      library: {
                        scales: {
                          x: { ticks: { color: "#9ca3af" }, grid: { color: "#1f2937" } },
                          y: { ticks: { color: "#9ca3af" }, grid: { color: "#1f2937" } }
                        },
                        plugins: { legend: { display: false } }
                      } %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        <p class="text-gray-500 text-sm">No team data yet. Start scouting matches to see charts.</p>
      </div>
    <% end %>
  </div>

  <%# Top Teams Table %>
  <div class="scout-card overflow-hidden mb-6">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Team Rankings</h2>
      <%= link_to "View All", teams_path, class: "text-sm text-orange-400 hover:text-orange-300 transition-colors duration-150 font-medium" %>
    </div>
    <% if @team_summaries.any? %>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr class="border-b border-gray-800">
              <th scope="col" class="text-left">#</th>
              <th scope="col" class="text-left">Team</th>
              <th scope="col" class="text-right hidden sm:table-cell">Avg Pts</th>
              <th scope="col" class="text-right hidden sm:table-cell">Accuracy</th>
              <th scope="col" class="text-right hidden md:table-cell">Avg Climb</th>
              <th scope="col" class="text-right">Scouted</th>
            </tr>
          </thead>
          <tbody>
            <% @team_summaries.limit(15).includes(:frc_team).each_with_index do |summary, idx| %>
              <tr>
                <td class="text-gray-400 font-mono"><%= idx + 1 %></td>
                <td>
                  <%= link_to team_path(summary.frc_team), class: "hover:text-orange-400 transition-colors duration-150 inline-flex items-center gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500" do %>
                    <span class="font-semibold text-white"><%= summary.frc_team.team_number %></span>
                    <span class="text-gray-500 text-xs hidden sm:inline"><%= summary.frc_team.nickname %></span>
                  <% end %>
                </td>
                <td class="text-right font-mono text-orange-400 hidden sm:table-cell"><%= summary.avg_total_points.to_f.round(1) %></td>
                <td class="text-right hidden sm:table-cell">
                  <div class="flex items-center justify-end gap-2">
                    <div class="w-16 h-1.5 bg-gray-800 rounded-full overflow-hidden" role="progressbar" aria-valuenow="<%= summary.fuel_accuracy_pct.to_f.round(0) %>" aria-valuemin="0" aria-valuemax="100" aria-label="<%= summary.fuel_accuracy_pct.to_f.round(0) %>% accuracy">
                      <div class="h-full rounded-full transition-all duration-500 <%= summary.fuel_accuracy_pct.to_f >= 70 ? 'bg-orange-500' : summary.fuel_accuracy_pct.to_f >= 40 ? 'bg-amber-500' : 'bg-red-500' %>" style="width: <%= summary.fuel_accuracy_pct.to_f.round(0) %>%"></div>
                    </div>
                    <span class="text-xs font-mono text-gray-400"><%= summary.fuel_accuracy_pct.to_f.round(0) %>%</span>
                  </div>
                </td>
                <td class="text-right font-mono text-gray-300 hidden md:table-cell"><%= summary.avg_climb_points.to_f.round(1) %></td>
                <td class="text-right font-mono text-gray-400"><%= summary.matches_scouted %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 px-4">
        <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-gray-500 text-sm font-medium mb-1">No teams ranked yet</p>
        <p class="text-gray-600 text-xs">Scout some matches to see team rankings here.</p>
      </div>
    <% end %>
  </div>

  <%# Recent Entries %>
  <div class="scout-card overflow-hidden">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Recent Entries</h2>
      <%= link_to "View All", scouting_entries_path, class: "text-sm text-orange-400 hover:text-orange-300 transition-colors duration-150 font-medium" %>
    </div>
    <% if @recent_entries.any? %>
      <div class="divide-y divide-gray-800/50">
        <% @recent_entries.includes(:user, :frc_team, :match).each do |entry| %>
          <%= link_to scouting_entry_path(entry), class: "flex items-center justify-between px-4 sm:px-6 py-3 hover:bg-gray-800/30 transition-colors duration-150 group" do %>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center group-hover:bg-gray-700/70 transition-colors duration-150">
                <span class="text-sm font-bold text-orange-400"><%= entry.frc_team.team_number %></span>
              </div>
              <div>
                <p class="text-sm font-medium text-white group-hover:text-orange-400 transition-colors duration-150">
                  Team <%= entry.frc_team.team_number %>
                  <% if entry.match %>
                    <span class="text-gray-600">&middot;</span>
                    <span class="text-gray-400"><%= entry.match.display_name %></span>
                  <% end %>
                </p>
                <p class="text-xs text-gray-500"><%= entry.user.full_name %> &middot; <%= time_ago_in_words(entry.created_at) %> ago</p>
              </div>
            </div>
            <div class="text-right flex items-center gap-3">
              <div>
                <p class="text-sm font-bold text-white font-mono"><%= entry.total_points %> pts</p>
                <span class="<%= case entry.status
                    when 'submitted' then 'badge-orange'
                    when 'flagged' then 'badge-amber'
                    when 'rejected' then 'badge-red'
                    else 'badge-gray'
                    end %> text-[10px]">
                  <%= entry.status&.capitalize || 'Draft' %>
                </span>
              </div>
              <svg class="w-4 h-4 text-gray-600 group-hover:text-gray-400 transition-colors duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 px-4">
        <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p class="text-gray-500 text-sm font-medium mb-1">No entries yet</p>
        <p class="text-gray-600 text-xs mb-4">Start scouting matches to see entries here.</p>
        <%= link_to "Scout a Match", new_scouting_entry_path, class: "btn-primary text-sm" %>
      </div>
    <% end %>
  </div>
