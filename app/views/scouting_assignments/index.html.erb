<% content_for(:title) { "Scouting Schedule - Watchtower" } %>

<div class="space-y-4">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-white">Scouting Schedule</h1>
      <p class="text-sm text-gray-400 mt-1">
        <%= current_event.name %><% if @is_admin %> &mdash; coverage target is 3 scouts per match.<% end %>
      </p>
    </div>
    <% if @is_admin %>
      <div class="flex items-center gap-2 text-xs">
        <span class="badge-red">&lt; 3</span>
        <span class="badge-emerald">= 3</span>
        <span class="badge-amber">&gt; 3</span>
      </div>
    <% end %>
  </div>

  <%# --- Admin Bulk Panel (consolidated single form) --- %>
  <% if @is_admin %>
    <details class="scout-card group" open>
      <summary class="flex items-center gap-2 p-4 cursor-pointer select-none list-none">
        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <div>
          <h2 class="text-sm font-semibold text-white">Bulk Assignment Manager</h2>
          <p class="text-xs text-gray-500 mt-0.5">Pick scouts from the checklist, then assign or clear a match range.</p>
        </div>
        <svg class="w-4 h-4 text-gray-500 ml-auto transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>

      <div class="px-4 pb-4">
        <%= form_with url: bulk_create_scouting_assignments_path, method: :post, class: "space-y-4" do %>
          <div>
            <label class="block text-xs text-gray-400 uppercase tracking-wider mb-2">Scout Checklist</label>
            <div class="max-h-48 overflow-y-auto rounded-xl border border-gray-800 bg-gray-950/40 p-2">
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-2">
                <% @users.each do |user| %>
                  <label class="flex items-center gap-2 rounded-lg border border-gray-800 bg-gray-900/70 px-3 py-2 text-sm text-gray-300 cursor-pointer transition hover:border-gray-700 has-[:checked]:border-orange-500/40 has-[:checked]:bg-orange-500/10 has-[:checked]:text-orange-200">
                    <%= check_box_tag "user_ids[]", user.id, false, class: "h-4 w-4 rounded border-gray-600 bg-gray-900 text-orange-500 focus:ring-orange-500" %>
                    <span class="font-medium"><%= user.full_name %></span>
                    <span class="ml-auto text-[10px] uppercase tracking-wide text-gray-500"><%= user.role.humanize %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 items-end">
            <div class="lg:col-span-3">
              <label class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Start Match</label>
              <%= number_field_tag :start_match_number, nil, min: 1, class: "input-field", required: true, placeholder: "1" %>
            </div>

            <div class="lg:col-span-3">
              <label class="block text-xs text-gray-400 uppercase tracking-wider mb-1">End Match</label>
              <%= number_field_tag :end_match_number, nil, min: 1, class: "input-field", placeholder: "10" %>
            </div>

            <div class="lg:col-span-3">
              <label class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Notes</label>
              <%= text_field_tag :notes, nil, class: "input-field", placeholder: "Optional" %>
            </div>

            <div class="lg:col-span-3 flex gap-2">
              <%= submit_tag "Assign Range", class: "btn-primary flex-1 text-sm" %>
              <%= submit_tag "Clear Range",
                  formaction: bulk_destroy_scouting_assignments_path,
                  class: "btn-danger flex-1 text-sm",
                  data: { turbo_confirm: "Clear all assignments in this range?" } %>
            </div>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>

  <%# --- Schedule View --- %>
  <% if @matches.any? %>
    <% if @is_admin %>
      <%# Admin: full grid with all users x all matches %>
      <div class="scout-card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-max w-full text-xs">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="sticky left-0 z-20 bg-gray-900 text-left p-2 text-gray-400 uppercase tracking-wider min-w-28">Scout</th>
                <% @matches.each do |match| %>
                  <% count = @coverage_counts[match.id].to_i %>
                  <th class="p-2 min-w-[4.5rem] border-l border-gray-800 text-center">
                    <%= render "coverage_header", match: match, count: count %>
                  </th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr class="border-b border-gray-800/60">
                  <td class="sticky left-0 z-10 bg-gray-900 p-2 border-r border-gray-800">
                    <div class="font-semibold text-white whitespace-nowrap"><%= user.full_name %></div>
                    <div class="text-[10px] text-gray-500"><%= user.role.humanize %></div>
                  </td>

                  <% @matches.each do |match| %>
                    <% assignment = @assignment_lookup[[user.id, match.id]] %>
                    <% is_shift_start = @shift_starts.include?([user.id, match.id]) %>
                    <td class="p-0.5 border-l border-gray-800 align-top">
                      <%= render "assignment_cell",
                          assignment: assignment,
                          user: user,
                          match: match,
                          is_admin: @is_admin,
                          is_shift_start: is_shift_start %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <%# Non-admin: clean shift blocks table %>
      <%= render "shift_blocks_table" %>
    <% end %>
  <% else %>
    <div class="scout-card p-8 text-center">
      <p class="text-gray-300 font-medium">No qualification matches available</p>
      <p class="text-sm text-gray-500 mt-1">Sync the event from TBA first, then build the schedule timeline.</p>
    </div>
  <% end %>
</div>
