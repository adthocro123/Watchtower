<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <title><%= content_for(:title) || "Lighthouse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Lighthouse">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#030712">
    <meta name="sw-cache-version" content="<%= Rails.application.config.sw_cache_version %>">
    <meta name="sign-in-url" content="<%= new_user_session_path %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 antialiased min-h-screen">
    <%# Skip to main content for keyboard users %>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-orange-600 focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Skip to main content
    </a>

    <%= turbo_stream_from "scouting_entries" if user_signed_in? %>

    <%# Top navigation %>
    <%= render "shared/nav" unless devise_controller? %>

    <%# Toast notification stack (fixed bottom-left) %>
    <div id="toast-stack" class="fixed bottom-20 lg:bottom-4 left-4 z-50 flex flex-col gap-2 max-w-sm" data-controller="connectivity">
      <%# Connectivity / sync toast %>
      <div data-connectivity-target="banner" class="hidden">
        <div class="rounded-lg bg-gray-900 border border-gray-700 shadow-lg shadow-black/30 text-sm overflow-hidden">
          <div class="px-4 py-3 flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728M5.636 5.636a9 9 0 000 12.728" />
            </svg>
            <span data-connectivity-target="status" class="flex-1 text-gray-200 text-xs">You are offline</span>
            <span data-connectivity-target="queueCount" class="hidden text-[10px] font-bold text-amber-400"></span>
            <button data-action="click->connectivity#retrySync" class="text-[10px] text-gray-400 hover:text-gray-200 transition" aria-label="Retry sync">Retry</button>
            <button data-action="click->connectivity#toggleDetails" class="text-gray-500 hover:text-gray-300 transition p-0.5" aria-label="Toggle details">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
          </div>
          <div data-connectivity-target="progress" class="hidden px-4 pb-2">
            <div class="w-full bg-gray-800 rounded-full h-1">
              <div data-connectivity-target="progressBar" class="bg-orange-500 h-1 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <span data-connectivity-target="progressText" class="text-[10px] text-gray-500 mt-1 block"></span>
          </div>
          <div data-connectivity-target="details" class="hidden border-t border-gray-800 px-4 py-2 max-h-40 overflow-y-auto">
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">Queued Entries</span>
              <button data-action="connectivity#clearFailed" class="text-[10px] text-red-400 hover:text-red-300 transition">Clear failed</button>
            </div>
            <ul data-connectivity-target="detailsList" class="space-y-0">
              <li class="text-xs text-gray-500 py-1.5 text-center">No queued entries</li>
            </ul>
          </div>
        </div>
      </div>

      <%# Flash toasts %>
      <%= render "shared/flash" %>
    </div>

    <%# Main content area %>
    <main id="main-content" class="<%= devise_controller? ? 'pb-6' : 'pt-16 pb-20 lg:pb-6' %> min-h-screen" role="main">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <%= yield %>
      </div>
    </main>

    <%# Mobile bottom navigation %>
    <%= render "shared/mobile_nav" unless devise_controller? %>
  </body>
</html>
