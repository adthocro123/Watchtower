<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <title><%= content_for(:title) || "Lighthouse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="application-name" content="Lighthouse">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#030712">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 antialiased min-h-screen">
    <%# Skip to main content for keyboard users %>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-orange-600 focus:text-white focus:rounded-lg focus:text-sm focus:font-medium">
      Skip to main content
    </a>

    <%= turbo_stream_from "scouting_entries" if user_signed_in? %>

    <%# Top navigation %>
    <%= render "shared/nav" %>

    <%# Offline / sync indicator %>
    <div data-controller="connectivity">
      <div data-connectivity-target="banner" class="hidden fixed top-14 left-0 right-0 z-40 bg-amber-600/90 backdrop-blur-sm text-white text-xs text-center py-1.5 px-4 flex items-center justify-center gap-3">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728M5.636 5.636a9 9 0 000 12.728" />
        </svg>
        <span data-connectivity-target="status">You are offline</span>
        <span data-connectivity-target="queueCount" class="hidden bg-white/20 px-1.5 py-0.5 rounded-full text-[10px] font-bold"></span>
        <button data-action="connectivity#retrySync" class="ml-2 underline hover:no-underline text-white/80 hover:text-white">Retry</button>
      </div>
    </div>

    <%# Main content area %>
    <main id="main-content" class="pt-16 pb-20 md:pb-6 min-h-screen" role="main">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    </main>

    <%# Mobile bottom navigation %>
    <%= render "shared/mobile_nav" %>
  </body>
</html>
