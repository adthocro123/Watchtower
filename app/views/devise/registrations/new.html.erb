<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <%# Branding %>
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-emerald-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-emerald-500/20">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">Join ScoutRail</h1>
      <p class="text-gray-400 text-sm mt-1">Create your scouting account</p>
    </div>

    <%# Registration Card %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl">
      <h2 class="text-xl font-bold text-white mb-6">Sign Up</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
                placeholder: "First" %>
          </div>
          <div>
            <%= f.label :last_name, class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.text_field :last_name, autocomplete: "family-name",
                class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
                placeholder: "Last" %>
          </div>
        </div>

        <div>
          <%= f.label :team_number, "FRC Team Number", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.number_field :team_number, autocomplete: "off",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "e.g., 254" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "you@team254.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-500 mb-1"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "Create a password" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "Confirm password" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Create Account", class: "w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-lg transition cursor-pointer shadow-lg shadow-emerald-500/20" %>
        </div>
      <% end %>

      <%# Links %>
      <div class="mt-6 pt-6 border-t border-gray-800 text-center">
        <p class="text-sm text-gray-400">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "text-emerald-400 hover:text-emerald-300 font-medium transition" %>
        </p>
      </div>
    </div>
  </div>
</div>
