<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md animate-fade-in">
    <%# Branding %>
    <div class="text-center mb-8">
      <img src="/icon.svg" alt="Lighthouse" class="w-16 h-16 rounded-2xl mx-auto mb-4" />
      <h1 class="text-2xl font-bold text-white">Join Lighthouse</h1>
      <p class="text-gray-400 text-sm mt-1">Create your scouting account</p>
    </div>

    <%# Registration Card %>
    <div class="scout-card rounded-2xl p-6 sm:p-8 shadow-xl">
      <h2 class="text-xl font-bold text-white mb-6">Sign Up</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", required: true,
                class: "input-field py-2.5",
                placeholder: "First" %>
          </div>
          <div>
            <%= f.label :last_name, class: "block text-sm font-medium text-gray-300 mb-1" %>
            <%= f.text_field :last_name, autocomplete: "family-name", required: true,
                class: "input-field py-2.5",
                placeholder: "Last" %>
          </div>
        </div>

        <div>
          <%= f.label :team_number, "FRC Team Number", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.number_field :team_number, autocomplete: "off", required: true,
              class: "input-field py-2.5",
              placeholder: "e.g., 254" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", required: true,
              class: "input-field py-2.5",
              placeholder: "you@harborps.org" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-400 mb-1" id="password-hint"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", required: true,
              class: "input-field py-2.5",
              placeholder: "Create a password",
              "aria-describedby": (@minimum_password_length ? "password-hint" : nil) %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true,
              class: "input-field py-2.5",
              placeholder: "Confirm password" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Create Account", class: "w-full py-2.5 bg-orange-600 hover:bg-orange-500 active:bg-orange-700 text-white font-semibold rounded-lg transition-all duration-150 cursor-pointer shadow-lg shadow-orange-500/20 hover:shadow-orange-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950" %>
        </div>
      <% end %>

      <%# Links %>
      <div class="mt-6 pt-6 border-t border-gray-800 text-center">
        <p class="text-sm text-gray-400">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "text-orange-400 hover:text-orange-300 font-medium transition-colors duration-150" %>
        </p>
      </div>
    </div>
  </div>
</div>
