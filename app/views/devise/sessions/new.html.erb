<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md animate-fade-in">
    <%# Branding %>
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-orange-500/20">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">Lighthouse</h1>
      <p class="text-gray-400 text-sm mt-1">FRC Scouting Platform</p>
    </div>

    <%# Login Card %>
    <div class="scout-card rounded-2xl p-6 sm:p-8 shadow-xl">
      <h2 class="text-xl font-bold text-white mb-6">Sign In</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :username, "Name", class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.text_field :username, autofocus: true, autocomplete: "username", required: true,
              class: "input-field py-2.5",
              placeholder: "Your full name" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
              class: "input-field py-2.5",
              placeholder: "Your password" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Sign In", class: "w-full py-2.5 bg-orange-600 hover:bg-orange-500 active:bg-orange-700 text-white font-semibold rounded-lg transition-all duration-150 cursor-pointer shadow-lg shadow-orange-500/20 hover:shadow-orange-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
