<div class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <%# Branding %>
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-emerald-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-emerald-500/20">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-white">ScoutRail</h1>
      <p class="text-gray-400 text-sm mt-1">FRC Scouting Platform</p>
    </div>

    <%# Login Card %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl">
      <h2 class="text-xl font-bold text-white mb-6">Sign In</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "you@team254.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition",
              placeholder: "Your password" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded bg-gray-800 border-gray-700 text-emerald-500 focus:ring-emerald-500 focus:ring-offset-gray-900" %>
            <%= f.label :remember_me, class: "text-sm text-gray-400" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Sign In", class: "w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-lg transition cursor-pointer shadow-lg shadow-emerald-500/20" %>
        </div>
      <% end %>

      <%# Links %>
      <div class="mt-6 pt-6 border-t border-gray-800 space-y-2 text-center">
        <%- if devise_mapping.registerable? %>
          <p class="text-sm text-gray-400">
            Don't have an account?
            <%= link_to "Sign up", new_registration_path(resource_name), class: "text-emerald-400 hover:text-emerald-300 font-medium transition" %>
          </p>
        <% end %>
        <%- if devise_mapping.recoverable? %>
          <p>
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-sm text-gray-500 hover:text-gray-400 transition" %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
