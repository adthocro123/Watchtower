<% content_for(:title) { "Teams - Lighthouse" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Team Rankings</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @teams.count %> teams at <%= current_event.name %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to new_match_simulator_path, class: "btn-secondary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
      <span class="hidden sm:inline ml-1">Simulate</span>
    <% end %>
  </div>
</div>

<%# Search with Stimulus search controller %>
<div class="mb-4" data-controller="search">
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input type="text"
           placeholder="Search teams..."
           aria-label="Search teams by number or name"
           class="input-field pl-10"
           data-action="input->search#filter"
           data-search-target="input">
  </div>

  <div class="scout-card overflow-hidden mt-4">
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead class="sticky top-0 bg-gray-900 z-10">
          <tr class="border-b border-gray-800">
            <th scope="col" class="text-left">#</th>
            <th scope="col" class="text-left">Team</th>
            <th scope="col" class="text-right">Avg Pts</th>
            <th scope="col" class="text-right hidden sm:table-cell">EPA</th>
            <th scope="col" class="text-right hidden sm:table-cell">Accuracy</th>
            <th scope="col" class="text-right hidden md:table-cell">Record</th>
            <th scope="col" class="text-right hidden lg:table-cell">Std Dev</th>
            <th scope="col" class="text-right">Scouted</th>
          </tr>
        </thead>
        <tbody>
          <% sorted_teams = @teams.sort_by { |t|
            scouted = @summaries[t.id]&.avg_total_points.to_f || 0
            epa = @statbotics_epa[t.id]&.epa_mean.to_f || 0
            -(scouted > 0 ? scouted : epa)
          } %>
          <% sorted_teams.each_with_index do |team, idx| %>
            <% summary = @summaries[team.id] %>
            <tr data-search-target="item"
                data-search="<%= team.team_number %> <%= team.nickname&.downcase %>">
              <td class="text-gray-400 font-mono text-xs"><%= idx + 1 %></td>
              <td>
                <%= link_to team_path(team), class: "hover:text-orange-400 transition-colors duration-150 group inline-flex items-center gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500" do %>
                  <span class="font-bold text-white group-hover:text-orange-400"><%= team.team_number %></span>
                  <span class="text-gray-500 text-xs hidden sm:inline"><%= team.nickname %></span>
                <% end %>
              </td>
              <% epa_data = @statbotics_epa[team.id] %>
              <td class="text-right">
                <span class="font-mono font-bold text-orange-400"><%= summary&.avg_total_points.to_f.round(1) || "---" %></span>
              </td>
              <td class="text-right hidden sm:table-cell">
                <span class="font-mono font-semibold text-emerald-400"><%= epa_data ? epa_data.epa_mean.round(1) : "---" %></span>
              </td>
              <td class="text-right hidden sm:table-cell">
                <% acc = summary&.fuel_accuracy_pct.to_f.round(0) || 0 %>
                <div class="flex items-center justify-end gap-2">
                  <div class="w-16 h-1.5 bg-gray-800 rounded-full overflow-hidden" role="progressbar" aria-valuenow="<%= acc %>" aria-valuemin="0" aria-valuemax="100" aria-label="<%= acc %>% accuracy">
                    <div class="h-full rounded-full transition-all duration-500
                      <%= if acc >= 70 then 'bg-orange-500'
                          elsif acc >= 40 then 'bg-amber-500'
                          else 'bg-red-500'
                          end %>"
                      style="width: <%= acc %>%"></div>
                  </div>
                  <span class="text-xs font-mono text-gray-400 w-8 text-right"><%= acc %>%</span>
                </div>
              </td>
              <td class="text-right hidden md:table-cell">
                <% if epa_data %>
                  <span class="font-mono text-gray-300"><%= epa_data.record %></span>
                  <span class="text-xs text-gray-500 ml-1">(<%= (epa_data.winrate * 100).round(0) %>%)</span>
                <% else %>
                  <span class="font-mono text-gray-500">---</span>
                <% end %>
              </td>
              <td class="text-right font-mono text-gray-500 hidden lg:table-cell"><%= summary&.stddev_total_points.to_f.round(1) || "---" %></td>
              <td class="text-right font-mono text-gray-400"><%= summary&.matches_scouted || 0 %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @teams.empty? %>
      <div class="text-center py-16 px-4">
        <svg class="w-12 h-12 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-gray-500 font-medium mb-1">No teams found</p>
        <p class="text-gray-600 text-sm">Sync from TBA to import teams for this event.</p>
      </div>
    <% end %>
  </div>
</div>
