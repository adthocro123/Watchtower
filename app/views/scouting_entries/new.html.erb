<% content_for(:title) { "Scout Match - Lighthouse" } %>

<div class="max-w-lg mx-auto">
  <div class="flex items-center gap-2 mb-4">
    <%= link_to scouting_entries_path, class: "back-link", "aria-label": "Back to entries" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white">Scout Match</h1>
    <span class="text-xs text-gray-400 ml-auto truncate max-w-32"><%= current_event.name %></span>
  </div>

  <div class="mb-4 rounded-xl border border-blue-500/20 bg-blue-500/10 p-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-sm font-semibold text-white">Need to scout a played match?</p>
        <p class="text-xs text-blue-100/70 mt-1">Replay scouting uses the official-match video workflow for past matches and highlights teams that still need coverage.</p>
      </div>
      <%= link_to "Open Replay Scout", replay_scouting_entries_path, class: "btn-secondary whitespace-nowrap" %>
    </div>
  </div>

  <%= render "form", scouting_entry: @scouting_entry, form_url: scouting_entries_path %>
</div>
