<% content_for(:title) { "Entry ##{@scouting_entry.id} - Lighthouse" } %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to scouting_entries_path, class: "back-link", "aria-label": "Back to entries" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white">
      Scouting Entry
      <span class="text-orange-400">#<%= @scouting_entry.frc_team.team_number %></span>
    </h1>
    <span class="ml-auto <%= case @scouting_entry.status
        when 'submitted' then 'badge-orange'
        when 'flagged' then 'badge-amber'
        when 'rejected' then 'badge-red'
        else 'badge-gray'
        end %>">
      <%= @scouting_entry.flagged? ? "Inaccurate" : (@scouting_entry.status&.capitalize || 'Draft') %>
    </span>
  </div>

  <%# Header Info %>
  <div class="scout-card p-5 mb-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Team</span>
        <p class="text-lg font-bold text-white mt-1">
          <%= link_to @scouting_entry.frc_team.team_number, team_path(@scouting_entry.frc_team), class: "text-orange-400 hover:text-orange-300 transition-colors duration-150 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500" %>
        </p>
        <p class="text-xs text-gray-500"><%= @scouting_entry.frc_team.nickname %></p>
      </div>
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Match</span>
        <p class="text-lg font-bold text-white mt-1"><%= @scouting_entry.match&.display_name || "N/A" %></p>
      </div>
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Scout</span>
        <p class="text-lg font-bold text-white mt-1"><%= @scouting_entry.user.full_name %></p>
        <p class="text-xs text-gray-500 mt-1"><%= @scouting_entry.mode_label %> scouting</p>
      </div>
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Total Points</span>
        <p class="text-lg font-bold text-orange-400 mt-1 font-mono"><%= @scouting_entry.total_points %></p>
      </div>
    </div>
  </div>

  <%# Entry Accuracy — compare scouted alliance total vs actual match score %>
  <% if @actual_score %>
    <div class="scout-card p-4 mb-4">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Entry Accuracy</h3>
        <span class="text-xs text-gray-600 ml-auto capitalize"><%= @alliance_color %> Alliance</span>
      </div>
      <% if @alliance_complete %>
        <div class="grid grid-cols-3 gap-4 text-center mb-3">
          <div>
            <p class="text-2xl font-bold text-white font-mono"><%= @scouted_total %></p>
            <p class="text-xs text-gray-400">Scouted Total</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-white font-mono"><%= @actual_score %></p>
            <p class="text-xs text-gray-400">Actual Score</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-mono <%= @alliance_error <= 10 ? 'text-emerald-400' : @alliance_error <= 20 ? 'text-amber-400' : 'text-red-400' %>">
              <%= @alliance_error %>
            </p>
            <p class="text-xs text-gray-400">Pts Off</p>
          </div>
        </div>
        <div class="flex items-center gap-3 text-xs text-gray-500">
          <span>This entry contributed <span class="text-white font-mono font-medium"><%= @this_entry_points %></span> of the <span class="text-white font-mono font-medium"><%= @scouted_total %></span> scouted points</span>
        </div>
      <% else %>
        <div class="grid grid-cols-2 gap-4 text-center mb-3">
          <div>
            <p class="text-2xl font-bold text-white font-mono"><%= @this_entry_points %></p>
            <p class="text-xs text-gray-400">This Entry</p>
          </div>
          <div>
            <p class="text-2xl font-bold text-white font-mono"><%= @actual_score %></p>
            <p class="text-xs text-gray-400">Actual Score</p>
          </div>
        </div>
        <p class="text-xs text-gray-500">Full alliance comparison unavailable — not all 3 teams on this alliance were scouted in this match.</p>
      <% end %>
    </div>
  <% end %>

  <%# Scoring Summary - Phase cards with color-coded borders %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <%# Auton %>
    <div class="scout-card p-4 border-l-4 border-l-orange-500/50">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Autonomous</h3>
      </div>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400 font-mono"><%= @scouting_entry.data&.dig("auton_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400 font-mono"><%= @scouting_entry.data&.dig("auton_fuel_missed") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Climb</span>
          <span class="text-sm font-bold <%= @scouting_entry.data&.dig('auton_climb').to_s == 'true' ? 'text-orange-400' : 'text-gray-600' %>">
            <%= @scouting_entry.data&.dig("auton_climb").to_s == "true" ? "Yes" : "No" %>
          </span>
        </div>
        <% auton_path = @scouting_entry.data&.dig("auton_path") %>
        <% if auton_path.present? && auton_path.is_a?(Array) && auton_path.any? %>
          <div class="pt-2 border-t border-gray-800">
            <span class="text-xs text-gray-500">Auton Path:</span>
            <div class="mt-1 relative rounded-lg overflow-hidden border border-gray-700"
                 data-controller="field-map"
                 data-field-map-strokes-value="<%= auton_path.to_json %>"
                 data-field-map-readonly-value="true">
              <%= image_tag "field_2026.jpeg", class: "w-full block select-none pointer-events-none", alt: "Field map", data: { field_map_target: "image" } %>
              <canvas class="absolute inset-0 w-full h-full"
                      data-field-map-target="canvas"></canvas>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Teleop %>
    <div class="scout-card p-4 border-l-4 border-l-blue-500/50">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Teleop</h3>
      </div>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400 font-mono"><%= @scouting_entry.data&.dig("teleop_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400 font-mono"><%= @scouting_entry.data&.dig("teleop_fuel_missed") || 0 %></span>
        </div>
        <% teleop_made = (@scouting_entry.data&.dig("teleop_fuel_made") || 0).to_i
           teleop_missed = (@scouting_entry.data&.dig("teleop_fuel_missed") || 0).to_i
           teleop_total = teleop_made + teleop_missed
           teleop_acc = teleop_total > 0 ? (teleop_made.to_f / teleop_total * 100).round(1) : 0 %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Accuracy</span>
          <span class="text-sm font-bold text-amber-400 font-mono"><%= teleop_acc %>%</span>
        </div>
      </div>
    </div>

    <%# Endgame %>
    <div class="scout-card p-4 border-l-4 border-l-amber-500/50">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Endgame</h3>
      </div>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400 font-mono"><%= @scouting_entry.data&.dig("endgame_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400 font-mono"><%= @scouting_entry.data&.dig("endgame_fuel_missed") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Climb Level</span>
          <% climb = @scouting_entry.data&.dig("endgame_climb") || "None" %>
          <span class="text-sm font-bold font-mono
            <%= case climb
                when 'L3' then 'text-orange-400'
                when 'L2' then 'text-blue-400'
                when 'L1' then 'text-amber-400'
                else 'text-gray-600'
                end %>">
            <%= climb %>
          </span>
        </div>
        <% defense = @scouting_entry.defense_rating %>
        <% if defense > 0 %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-400">Defense</span>
            <span class="text-sm font-bold font-mono
              <%= case defense
                  when 5 then 'text-orange-400'
                  when 4 then 'text-emerald-400'
                  when 3 then 'text-amber-400'
                  when 2 then 'text-gray-400'
                  else 'text-gray-600'
                  end %>">
              <%= defense %>/5
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Overall Stats Bar %>
  <div class="scout-card p-4 mb-4">
    <h3 class="text-xs text-gray-400 uppercase tracking-wider mb-3 font-medium">Overall</h3>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-2xl font-bold text-emerald-400 font-mono"><%= @scouting_entry.total_fuel_made %></p>
        <p class="text-xs text-gray-400">Total Made</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-red-400 font-mono"><%= @scouting_entry.total_fuel_missed %></p>
        <p class="text-xs text-gray-400">Total Missed</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-amber-400 font-mono"><%= @scouting_entry.fuel_accuracy %>%</p>
        <p class="text-xs text-gray-400">Accuracy</p>
      </div>
    </div>
    <%# Accuracy bar %>
    <div class="mt-3 w-full h-2 bg-gray-800 rounded-full overflow-hidden" role="progressbar" aria-valuenow="<%= @scouting_entry.fuel_accuracy %>" aria-valuemin="0" aria-valuemax="100" aria-label="Overall accuracy: <%= @scouting_entry.fuel_accuracy %>%">
      <div class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full transition-all duration-500" style="width: <%= @scouting_entry.fuel_accuracy %>%"></div>
    </div>
  </div>

  <%# Notes %>
  <% if @scouting_entry.notes.present? %>
    <div class="scout-card p-4 mb-4">
      <h3 class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-medium">Notes</h3>
      <p class="text-sm text-gray-300 whitespace-pre-wrap leading-relaxed"><%= @scouting_entry.notes %></p>
    </div>
  <% end %>

  <% if @scouting_entry.replay? && @scouting_entry.match&.replay_available? %>
    <div class="scout-card p-4 mb-4">
      <% replay_watch_url = replay_watch_url_for(@scouting_entry.match, @scouting_entry.video_key) %>
      <div class="flex items-center justify-between gap-3 mb-3">
        <div>
          <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Replay Source</h3>
          <p class="text-sm text-gray-300 mt-1">This entry was captured from a replay video source.</p>
        </div>
        <%= link_to "Open Video", replay_watch_url, class: "btn-secondary", target: "_blank", rel: "noopener" if replay_watch_url.present? %>
      </div>
      <% if @scouting_entry.video_key.present? %>
        <p class="text-xs text-gray-500 font-mono break-all"><%= @scouting_entry.video_key %></p>
      <% end %>
    </div>
  <% end %>

  <%# QR Code for Offline Transfer %>
  <details class="scout-card mb-4 group">
    <summary class="flex items-center gap-2 p-4 cursor-pointer select-none list-none">
      <svg class="w-5 h-5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
      </svg>
      <span class="text-sm font-medium text-gray-300">QR Code for Offline Transfer</span>
      <svg class="w-4 h-4 text-gray-500 ml-auto transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <div class="px-4 pb-4">
      <p class="text-xs text-gray-500 mb-3">Have an analyst or admin scan this code to import this entry without internet.</p>
      <%
        qr_entry = {
          client_uuid: @scouting_entry.client_uuid,
          match_key:   @scouting_entry.match&.tba_key,
          team_number: @scouting_entry.frc_team.team_number,
          event_key:   @scouting_entry.event.tba_key,
          notes:       @scouting_entry.notes,
          status:      ScoutingEntry.statuses[@scouting_entry.status],
          scouting_mode: @scouting_entry.scouting_mode,
          video_key:   @scouting_entry.video_key,
          video_type:  @scouting_entry.video_type,
          updated_at:  @scouting_entry.updated_at&.iso8601,
          data:        @scouting_entry.data || {},
        }
      %>
      <div class="flex flex-col items-center"
           data-controller="qr-generator"
           data-qr-generator-entry-value="<%= qr_entry.to_json %>">
        <canvas data-qr-generator-target="canvas" class="rounded-lg"></canvas>
        <p data-qr-generator-target="error" class="hidden text-sm text-red-400 mt-2"></p>
        <p class="text-xs text-gray-600 mt-2">
          Payload: <span data-qr-generator-target="size" class="font-mono">--</span>
        </p>
      </div>
    </div>
  </details>

  <%# Actions %>
  <div class="flex items-center gap-3 mt-4">
    <% if @next_match.present? && @scouting_entry.live? %>
      <%= link_to "Scout Next Match", new_scouting_entry_path(match_id: @next_match.id), class: "btn-primary" %>
    <% end %>
    <% if policy(@scouting_entry).update? %>
      <%= link_to "Edit", edit_scouting_entry_path(@scouting_entry), class: "btn-secondary" %>
    <% end %>
    <% if policy(@scouting_entry).destroy? %>
      <%= button_to "Delete", scouting_entry_path(@scouting_entry), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this entry?" }, class: "btn-danger" %>
    <% end %>
    <span class="text-xs text-gray-600 ml-auto">Created <%= time_ago_in_words(@scouting_entry.created_at) %> ago</span>
  </div>
</div>
