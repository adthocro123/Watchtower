<% content_for(:title) { "Entry ##{@scouting_entry.id} - ScoutRail" } %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to scouting_entries_path, class: "text-gray-500 hover:text-gray-300 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white">
      Scouting Entry
      <span class="text-emerald-400">#<%= @scouting_entry.frc_team.team_number %></span>
    </h1>
    <span class="text-xs font-medium px-2 py-0.5 rounded-full ml-auto
      <%= case @scouting_entry.status
          when 'submitted' then 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30'
          when 'flagged' then 'bg-amber-500/20 text-amber-400 border border-amber-500/30'
          when 'rejected' then 'bg-red-500/20 text-red-400 border border-red-500/30'
          end %>">
      <%= @scouting_entry.status.capitalize %>
    </span>
  </div>

  <%# Header Info %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Team</span>
        <p class="text-lg font-bold text-white mt-1">
          <%= link_to @scouting_entry.frc_team.team_number, team_path(@scouting_entry.frc_team), class: "text-emerald-400 hover:text-emerald-300 transition" %>
        </p>
        <p class="text-xs text-gray-400"><%= @scouting_entry.frc_team.nickname %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Match</span>
        <p class="text-lg font-bold text-white mt-1"><%= @scouting_entry.match&.display_name || "N/A" %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Scout</span>
        <p class="text-lg font-bold text-white mt-1"><%= @scouting_entry.user.full_name %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Total Points</span>
        <p class="text-lg font-bold text-emerald-400 mt-1"><%= @scouting_entry.total_points %></p>
      </div>
    </div>
  </div>

  <%# Scoring Summary %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <%# Auton %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-3">Autonomous</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400"><%= @scouting_entry.data&.dig("auton_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400"><%= @scouting_entry.data&.dig("auton_fuel_missed") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Climb</span>
          <span class="text-sm font-bold <%= @scouting_entry.data&.dig('auton_climb').to_s == 'true' ? 'text-emerald-400' : 'text-gray-600' %>">
            <%= @scouting_entry.data&.dig("auton_climb").to_s == "true" ? "Yes" : "No" %>
          </span>
        </div>
        <% if @scouting_entry.auton_actions.any? %>
          <div class="pt-2 border-t border-gray-800">
            <span class="text-xs text-gray-500">Actions:</span>
            <div class="flex flex-wrap gap-1 mt-1">
              <% @scouting_entry.auton_actions.each do |action| %>
                <span class="text-xs px-1.5 py-0.5 rounded bg-gray-800 text-gray-400"><%= action %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Teleop %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-3">Teleop</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400"><%= @scouting_entry.data&.dig("teleop_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400"><%= @scouting_entry.data&.dig("teleop_fuel_missed") || 0 %></span>
        </div>
        <% teleop_made = (@scouting_entry.data&.dig("teleop_fuel_made") || 0).to_i
           teleop_missed = (@scouting_entry.data&.dig("teleop_fuel_missed") || 0).to_i
           teleop_total = teleop_made + teleop_missed
           teleop_acc = teleop_total > 0 ? (teleop_made.to_f / teleop_total * 100).round(1) : 0 %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Accuracy</span>
          <span class="text-sm font-bold text-amber-400"><%= teleop_acc %>%</span>
        </div>
      </div>
    </div>

    <%# Endgame %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-3">Endgame</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Made</span>
          <span class="text-sm font-bold text-emerald-400"><%= @scouting_entry.data&.dig("endgame_fuel_made") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Fuel Missed</span>
          <span class="text-sm font-bold text-red-400"><%= @scouting_entry.data&.dig("endgame_fuel_missed") || 0 %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-400">Climb Level</span>
          <% climb = @scouting_entry.data&.dig("endgame_climb") || "None" %>
          <span class="text-sm font-bold
            <%= case climb
                when 'L3' then 'text-emerald-400'
                when 'L2' then 'text-blue-400'
                when 'L1' then 'text-amber-400'
                else 'text-gray-600'
                end %>">
            <%= climb %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <%# Overall Stats Bar %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
    <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-3">Overall</h3>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-2xl font-bold text-emerald-400"><%= @scouting_entry.total_fuel_made %></p>
        <p class="text-xs text-gray-500">Total Made</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-red-400"><%= @scouting_entry.total_fuel_missed %></p>
        <p class="text-xs text-gray-500">Total Missed</p>
      </div>
      <div>
        <p class="text-2xl font-bold text-amber-400"><%= @scouting_entry.fuel_accuracy %>%</p>
        <p class="text-xs text-gray-500">Accuracy</p>
      </div>
    </div>
    <%# Accuracy bar %>
    <div class="mt-3 w-full h-2 bg-gray-800 rounded-full overflow-hidden">
      <div class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full transition-all" style="width: <%= @scouting_entry.fuel_accuracy %>%"></div>
    </div>
  </div>

  <%# Notes %>
  <% if @scouting_entry.notes.present? %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-2">Notes</h3>
      <p class="text-sm text-gray-300 whitespace-pre-wrap"><%= @scouting_entry.notes %></p>
    </div>
  <% end %>

  <%# Actions %>
  <div class="flex items-center gap-2 mt-4">
    <%= link_to "Edit", edit_scouting_entry_path(@scouting_entry), class: "px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-lg transition" %>
    <%= button_to "Delete", scouting_entry_path(@scouting_entry), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this entry?" }, class: "px-4 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 text-sm font-medium rounded-lg transition border border-red-500/30" %>
    <span class="text-xs text-gray-600 ml-auto">Created <%= time_ago_in_words(@scouting_entry.created_at) %> ago</span>
  </div>
</div>
