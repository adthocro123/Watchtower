<% content_for(:title) { "Scouting Entries - Watchtower" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Scouting Entries</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @scouting_entries.count %> entries for <%= current_event.name %></p>
  </div>
  <div class="flex items-center gap-3">
    <% if current_user.admin? || current_user.analyst? %>
      <%= link_to scanner_qr_imports_path, class: "btn-secondary text-gray-300 hover:text-white" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
        </svg>
        <span class="hidden sm:inline ml-1.5">Scan QR</span>
      <% end %>
    <% end %>
    <%= link_to new_scouting_entry_path, class: "btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <span class="hidden sm:inline ml-1.5">New Entry</span>
    <% end %>
    <%= link_to replay_scouting_entries_path, class: "btn-secondary text-gray-300 hover:text-white" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.868v4.264a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="hidden sm:inline ml-1.5">Replay Scout</span>
    <% end %>
  </div>
</div>

<div class="scout-card overflow-hidden">
  <div id="scouting_entries" role="list">
    <% @scouting_entries.each do |entry| %>
      <%= render "scouting_entries/scouting_entry", scouting_entry: entry %>
    <% end %>
  </div>

  <% if @scouting_entries.empty? %>
    <div class="text-center py-16 px-4">
      <svg class="w-12 h-12 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="text-gray-500 font-medium mb-1">No scouting entries yet</p>
      <p class="text-gray-600 text-sm mb-4">Scout your first match to start collecting data.</p>
      <%= link_to "Start Scouting", new_scouting_entry_path, class: "btn-primary text-sm" %>
    </div>
  <% end %>
</div>
