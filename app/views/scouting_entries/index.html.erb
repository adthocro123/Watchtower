<% content_for(:title) { "Scouting Entries - ScoutRail" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Scouting Entries</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @scouting_entries.count %> entries for <%= current_event.name %></p>
  </div>
  <%= link_to new_scouting_entry_path, class: "flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    <span class="hidden sm:inline">New Entry</span>
  <% end %>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
  <div id="scouting_entries">
    <% @scouting_entries.each do |entry| %>
      <%= render "scouting_entries/scouting_entry", scouting_entry: entry %>
    <% end %>
  </div>

  <% if @scouting_entries.empty? %>
    <div class="text-center py-16">
      <svg class="w-12 h-12 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="text-gray-500 mb-4">No scouting entries yet.</p>
      <%= link_to "Start Scouting", new_scouting_entry_path, class: "inline-block px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" %>
    </div>
  <% end %>
</div>
