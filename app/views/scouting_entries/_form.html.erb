<%= form_with(model: scouting_entry, id: "scouting-form",
             data: {
               controller: "scouting",
               scouting_auton_made_value: scouting_entry.data&.dig("auton_fuel_made") || 0,
               scouting_auton_missed_value: scouting_entry.data&.dig("auton_fuel_missed") || 0,
               scouting_teleop_made_value: scouting_entry.data&.dig("teleop_fuel_made") || 0,
               scouting_teleop_missed_value: scouting_entry.data&.dig("teleop_fuel_missed") || 0,
               scouting_endgame_made_value: scouting_entry.data&.dig("endgame_fuel_made") || 0,
               scouting_endgame_missed_value: scouting_entry.data&.dig("endgame_fuel_missed") || 0,
               scouting_auton_climb_value: scouting_entry.data&.dig("auton_climb") || false,
               scouting_endgame_climb_value: scouting_entry.data&.dig("endgame_climb") || "None",
               action: "submit->scouting#submitForm"
             }) do |f| %>
  <% if scouting_entry.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-red-400 mb-2"><%= pluralize(scouting_entry.errors.count, "error") %> prevented this entry from being saved:</h3>
      <ul class="text-sm text-red-400/80 list-disc list-inside space-y-1">
        <% scouting_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# UUID for offline sync %>
  <%= f.hidden_field :client_uuid, value: scouting_entry.client_uuid || SecureRandom.uuid %>

  <%# Hidden field that receives the JSON payload on submit %>
  <%= f.hidden_field "data[_json]", value: "", data: { scouting_target: "dataField" } %>

  <%# ===== TEAM & MATCH SELECTOR ===== %>
  <div class="grid grid-cols-2 gap-3 mb-4">
    <div>
      <%= f.label :frc_team_id, "Team", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.select :frc_team_id,
            options_from_collection_for_select(@teams, :id, ->(t) { "#{t.team_number} - #{t.nickname}" }, scouting_entry.frc_team_id),
            { prompt: "Select team..." },
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" %>
    </div>
    <div>
      <%= f.label :match_id, "Match", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.select :match_id,
            options_from_collection_for_select(@matches, :id, :display_name, scouting_entry.match_id),
            { prompt: "Select match..." },
            class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" %>
    </div>
  </div>

  <%# ===== OVERALL SUMMARY BAR ===== %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-3 mb-4">
    <div class="grid grid-cols-4 gap-2 text-center">
      <div>
        <p class="text-xl font-bold text-emerald-400" data-scouting-target="totalMade">0</p>
        <p class="text-[10px] text-gray-500">Total Made</p>
      </div>
      <div>
        <p class="text-xl font-bold text-red-400" data-scouting-target="totalMissed">0</p>
        <p class="text-[10px] text-gray-500">Total Missed</p>
      </div>
      <div>
        <p class="text-xl font-bold text-amber-400" data-scouting-target="accuracy">0.0%</p>
        <p class="text-[10px] text-gray-500">Accuracy</p>
      </div>
      <div>
        <p class="text-xl font-bold text-white" data-scouting-target="totalPoints">0</p>
        <p class="text-[10px] text-gray-500">Points</p>
      </div>
    </div>
  </div>

  <%# ===== PHASE TABS ===== %>
  <div class="mb-4">
    <div class="flex rounded-xl bg-gray-800 p-1 gap-1" role="tablist">
      <button type="button" role="tab"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition border-b-2 border-emerald-400 text-emerald-400"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="auton"
              aria-selected="true">
        Auton
      </button>
      <button type="button" role="tab"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition border-b-2 border-transparent text-gray-400"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="teleop"
              aria-selected="false">
        Teleop
      </button>
      <button type="button" role="tab"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition border-b-2 border-transparent text-gray-400"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="endgame"
              aria-selected="false">
        Endgame
      </button>
    </div>
  </div>

  <%# ===== AUTON PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="auton">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider text-center mb-4">Autonomous Period</h3>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400" data-scouting-target="autonMade">0</p>
          <p class="text-xs text-gray-500">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400" data-scouting-target="autonMissed">0</p>
          <p class="text-xs text-gray-500">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="auton">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="auton">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="auton">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="auton">
          Undo Miss
        </button>
      </div>

      <%# Auton Actions - Pill Buttons %>
      <div class="mb-4">
        <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">Auton Actions</p>
        <div class="flex flex-wrap gap-2">
          <% %w[Mobility Preload Intake].each do |action_name| %>
            <button type="button"
                    class="px-4 py-2 text-sm font-medium rounded-full border border-gray-700 bg-gray-800 text-gray-400 transition active:scale-95 select-none hover:border-gray-600"
                    data-action="click->scouting#addAutonAction"
                    data-action-name="<%= action_name %>">
              <%= action_name %>
            </button>
          <% end %>
        </div>
      </div>

      <%# Auton Climb Toggle %>
      <div class="flex items-center justify-between bg-gray-800 rounded-lg px-4 py-3 cursor-pointer transition"
           data-action="click->scouting#toggleAutonClimb"
           data-scouting-target="autonClimb">
        <span class="text-sm font-medium text-gray-300">Auton Climb (+10 pts)</span>
        <div class="w-12 h-7 rounded-full transition-colors bg-gray-700 flex items-center">
          <div class="w-5 h-5 bg-white rounded-full shadow-sm transition-transform translate-x-1"></div>
        </div>
      </div>
    </div>
  </div>

  <%# ===== TELEOP PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="teleop" class="hidden">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider text-center mb-4">Teleop Period</h3>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400" data-scouting-target="teleopMade">0</p>
          <p class="text-xs text-gray-500">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400" data-scouting-target="teleopMissed">0</p>
          <p class="text-xs text-gray-500">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="teleop">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="teleop">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="teleop">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="teleop">
          Undo Miss
        </button>
      </div>

      <%# Live accuracy display %>
      <div class="bg-gray-800 rounded-lg p-3">
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs text-gray-500">Live Accuracy</span>
          <span class="text-xs font-mono text-amber-400" data-scouting-target="accuracy">0.0%</span>
        </div>
        <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-amber-500 to-emerald-500 rounded-full transition-all duration-300"
               style="width: 0%"></div>
        </div>
      </div>
    </div>
  </div>

  <%# ===== ENDGAME PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="endgame" class="hidden">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <h3 class="text-xs text-gray-500 uppercase tracking-wider text-center mb-4">Endgame</h3>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400" data-scouting-target="endgameMade">0</p>
          <p class="text-xs text-gray-500">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400" data-scouting-target="endgameMissed">0</p>
          <p class="text-xs text-gray-500">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="endgame">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="endgame">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="endgame">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 transition active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="endgame">
          Undo Miss
        </button>
      </div>

      <%# Climb Level Selector - Large Tappable Cards %>
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">Climb Level</p>
      <div class="grid grid-cols-4 gap-2 mb-4">
        <% [["None", 0], ["L1", 10], ["L2", 20], ["L3", 30]].each do |level, points| %>
          <button type="button"
                  class="py-4 rounded-xl border-2 text-center transition active:scale-95 select-none
                         <%= level == (scouting_entry.data&.dig('endgame_climb') || 'None') ? 'ring-2 ring-emerald-400 bg-emerald-900/50 border-emerald-500' : 'bg-gray-800 border-gray-700' %>"
                  data-action="click->scouting#selectClimb"
                  data-climb-card
                  data-level="<%= level %>">
            <p class="text-lg font-bold <%= level == (scouting_entry.data&.dig('endgame_climb') || 'None') ? 'text-emerald-400' : 'text-gray-300' %>"><%= level %></p>
            <p class="text-xs text-gray-500"><%= points %> pts</p>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== NOTES ===== %>
  <div class="mt-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <%= f.label :notes, class: "block text-xs text-gray-500 uppercase tracking-wider mb-2" %>
      <%= f.text_area :notes, rows: 3, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition resize-none", placeholder: "Defense quality, robot issues, strategy observations..." %>
    </div>
  </div>

  <%# ===== SUBMIT ===== %>
  <div class="mt-4 pb-4">
    <%= f.submit scouting_entry.persisted? ? "Update Entry" : "Submit Entry",
                 class: "w-full py-4 text-lg font-bold bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white rounded-xl transition-all active:scale-[0.98] cursor-pointer shadow-lg shadow-emerald-500/20" %>
  </div>
<% end %>
