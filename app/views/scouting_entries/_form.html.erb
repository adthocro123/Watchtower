<%= form_with(model: scouting_entry, id: "scouting-form",
              data: {
                controller: "scouting",
                scouting_match_teams_value: @match_teams.to_json,
                scouting_auton_made_value: scouting_entry.data&.dig("auton_fuel_made") || 0,
                scouting_auton_missed_value: scouting_entry.data&.dig("auton_fuel_missed") || 0,
                scouting_teleop_made_value: scouting_entry.data&.dig("teleop_fuel_made") || 0,
                scouting_teleop_missed_value: scouting_entry.data&.dig("teleop_fuel_missed") || 0,
                scouting_endgame_made_value: scouting_entry.data&.dig("endgame_fuel_made") || 0,
                scouting_endgame_missed_value: scouting_entry.data&.dig("endgame_fuel_missed") || 0,
                scouting_auton_climb_value: scouting_entry.data&.dig("auton_climb") || false,
                scouting_endgame_climb_value: scouting_entry.data&.dig("endgame_climb") || "None",
                action: "submit->scouting#submitForm"
              }) do |f| %>
  <% if scouting_entry.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 mb-4 animate-slide-down" role="alert">
      <h3 class="text-sm font-semibold text-red-400 mb-2"><%= pluralize(scouting_entry.errors.count, "error") %> prevented this entry from being saved:</h3>
      <ul class="text-sm text-red-400/80 list-disc list-inside space-y-1">
        <% scouting_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# UUID for offline sync %>
  <%= f.hidden_field :client_uuid, value: scouting_entry.client_uuid || SecureRandom.uuid %>

  <%# Hidden field that receives the JSON payload on submit %>
  <%= f.hidden_field "data[_json]", value: "", data: { scouting_target: "dataField" } %>

  <%# ===== MATCH & TEAM SELECTOR ===== %>
  <div class="grid grid-cols-2 gap-3 mb-4">
    <div>
      <%= f.label :match_id, "Match", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.select :match_id,
            options_from_collection_for_select(@matches, :id, :display_name, scouting_entry.match_id),
            { prompt: "Select match..." },
            { class: "input-field text-sm",
              data: { scouting_target: "matchSelect", action: "change->scouting#matchChanged" } } %>
    </div>
    <div>
      <%= f.label :frc_team_id, "Team", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <%= f.select :frc_team_id,
            options_from_collection_for_select(@teams, :id, ->(t) { "#{t.team_number} - #{t.nickname}" }, scouting_entry.frc_team_id),
            { prompt: "Select team..." },
            { class: "input-field text-sm",
              data: { scouting_target: "teamSelect" } } %>
    </div>
  </div>

  <%# ===== OVERALL SUMMARY BAR ===== %>
  <div class="scout-card p-3 mb-4" aria-live="polite" aria-atomic="true">
    <div class="grid grid-cols-4 gap-2 text-center">
      <div>
        <p class="text-xl font-bold text-emerald-400 font-mono" data-scouting-target="totalMade">0</p>
        <p class="text-[11px] text-gray-400 font-medium">Total Made</p>
      </div>
      <div>
        <p class="text-xl font-bold text-red-400 font-mono" data-scouting-target="totalMissed">0</p>
        <p class="text-[11px] text-gray-400 font-medium">Total Missed</p>
      </div>
      <div>
        <p class="text-xl font-bold text-amber-400 font-mono" data-scouting-target="summaryAccuracy">0.0%</p>
        <p class="text-[11px] text-gray-400 font-medium">Accuracy</p>
      </div>
      <div>
        <p class="text-xl font-bold text-white font-mono" data-scouting-target="totalPoints">0</p>
        <p class="text-[11px] text-gray-400 font-medium">Points</p>
      </div>
    </div>
  </div>

  <%# ===== PHASE TABS ===== %>
  <div class="mb-4">
    <div class="flex rounded-xl bg-gray-800/80 p-1 gap-1" role="tablist" aria-label="Match phases">
      <button type="button" role="tab"
              id="tab-auton"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 bg-orange-500/15 text-orange-400 shadow-sm"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="auton"
              aria-selected="true"
              aria-controls="panel-auton">
        Auton
      </button>
      <button type="button" role="tab"
              id="tab-teleop"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 text-gray-400 hover:text-gray-300 hover:bg-gray-700/50"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="teleop"
              aria-selected="false"
              aria-controls="panel-teleop">
        Teleop
      </button>
      <button type="button" role="tab"
              id="tab-endgame"
              class="flex-1 py-2.5 text-sm font-semibold rounded-lg transition-all duration-200 text-gray-400 hover:text-gray-300 hover:bg-gray-700/50"
              data-action="click->scouting#switchTab"
              data-tab-button
              data-tab="endgame"
              aria-selected="false"
              aria-controls="panel-endgame">
        Endgame
      </button>
    </div>
  </div>

  <%# ===== AUTON PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="auton" id="panel-auton" role="tabpanel" aria-labelledby="tab-auton">
    <div class="scout-card p-4 border-l-4 border-l-orange-500/50">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Autonomous Period</h3>
      </div>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400 font-mono" data-scouting-target="autonMade">0</p>
          <p class="text-xs text-gray-400">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400 font-mono" data-scouting-target="autonMissed">0</p>
          <p class="text-xs text-gray-400">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="auton"
                aria-label="Score made fuel in autonomous">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="auton"
                aria-label="Score missed fuel in autonomous">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="auton">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="auton">
          Undo Miss
        </button>
      </div>

      <%# Auton Actions - Pill Buttons with toggle state %>
      <div class="mb-4">
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-medium">Auton Actions</p>
        <div class="flex flex-wrap gap-2">
          <% %w[Mobility Preload Intake].each do |action_name| %>
            <button type="button"
                    class="px-4 py-2 text-sm font-medium rounded-full border border-gray-700 bg-gray-800 text-gray-400 transition-all duration-150 active:scale-95 select-none hover:border-gray-600 hover:text-gray-300"
                    data-action="click->scouting#addAutonAction"
                    data-action-name="<%= action_name %>"
                    data-auton-pill>
              <span class="inline-flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 hidden" data-check-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <%= action_name %>
              </span>
            </button>
          <% end %>
        </div>
      </div>

      <%# Auton Climb Toggle %>
      <div class="flex items-center justify-between bg-gray-800 rounded-lg px-4 py-3 cursor-pointer transition-all duration-150 hover:bg-gray-700/50"
           data-action="click->scouting#toggleAutonClimb"
           data-scouting-target="autonClimb"
           role="switch"
           aria-checked="<%= scouting_entry.data&.dig('auton_climb') == true ? 'true' : 'false' %>"
           aria-label="Toggle autonomous climb"
           tabindex="0">
        <span class="text-sm font-medium text-gray-300">Auton Climb (+10 pts)</span>
        <div class="w-12 h-7 rounded-full transition-colors duration-200 bg-gray-700 flex items-center relative" data-toggle-track>
          <div class="w-5 h-5 bg-white rounded-full shadow-md transition-all duration-200 absolute left-1" data-toggle-knob></div>
        </div>
      </div>
    </div>
  </div>

  <%# ===== TELEOP PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="teleop" class="hidden" id="panel-teleop" role="tabpanel" aria-labelledby="tab-teleop">
    <div class="scout-card p-4 border-l-4 border-l-blue-500/50">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Teleop Period</h3>
      </div>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400 font-mono" data-scouting-target="teleopMade">0</p>
          <p class="text-xs text-gray-400">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400 font-mono" data-scouting-target="teleopMissed">0</p>
          <p class="text-xs text-gray-400">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="teleop"
                aria-label="Score made fuel in teleop">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="teleop"
                aria-label="Score missed fuel in teleop">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="teleop">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="teleop">
          Undo Miss
        </button>
      </div>

      <%# Live accuracy display %>
      <div class="bg-gray-800 rounded-lg p-3">
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-xs text-gray-400 font-medium">Live Accuracy</span>
          <span class="text-xs font-mono text-amber-400 font-semibold" data-scouting-target="teleopAccuracy">0.0%</span>
        </div>
        <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden" role="progressbar" aria-label="Teleop accuracy">
          <div class="h-full bg-gradient-to-r from-amber-500 to-orange-500 rounded-full transition-all duration-300"
               data-scouting-target="accuracyBar"
               style="width: 0%"></div>
        </div>
      </div>
    </div>
  </div>

  <%# ===== ENDGAME PANEL ===== %>
  <div data-scouting-target="tabContent" data-tab-panel="endgame" class="hidden" id="panel-endgame" role="tabpanel" aria-labelledby="tab-endgame">
    <div class="scout-card p-4 border-l-4 border-l-amber-500/50">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-xs text-gray-400 uppercase tracking-wider font-medium">Endgame</h3>
      </div>

      <%# Score display %>
      <div class="grid grid-cols-2 gap-3 mb-4 text-center">
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-emerald-400 font-mono" data-scouting-target="endgameMade">0</p>
          <p class="text-xs text-gray-400">Made</p>
        </div>
        <div class="bg-gray-800 rounded-lg p-3">
          <p class="text-3xl font-bold text-red-400 font-mono" data-scouting-target="endgameMissed">0</p>
          <p class="text-xs text-gray-400">Missed</p>
        </div>
      </div>

      <%# HUGE MAKE / MISS buttons %>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 text-white shadow-lg shadow-emerald-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMade"
                data-phase="endgame"
                aria-label="Score made fuel in endgame">
          +MAKE
        </button>
        <button type="button"
                class="h-20 w-full text-4xl font-black rounded-xl bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-lg shadow-red-500/20 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#incrementMissed"
                data-phase="endgame"
                aria-label="Score missed fuel in endgame">
          +MISS
        </button>
      </div>

      <%# Undo buttons %>
      <div class="grid grid-cols-2 gap-3 mb-4">
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMade"
                data-phase="endgame">
          Undo Make
        </button>
        <button type="button"
                class="py-2 text-xs font-medium rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-300 transition-all duration-150 active:scale-95 select-none"
                data-action="click->scouting#undoMissed"
                data-phase="endgame">
          Undo Miss
        </button>
      </div>

      <%# Climb Level Selector - Large Tappable Cards %>
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-2 font-medium">Climb Level</p>
      <div class="grid grid-cols-4 gap-2 mb-4" role="radiogroup" aria-label="Select climb level">
        <% [["None", 0], ["L1", 10], ["L2", 20], ["L3", 30]].each do |level, points| %>
          <% is_selected = level == (scouting_entry.data&.dig('endgame_climb') || 'None') %>
          <button type="button"
                  class="py-4 rounded-xl border-2 text-center transition-all duration-200 active:scale-95 select-none
                         <%= is_selected ? 'ring-2 ring-orange-400 bg-orange-500/15 border-orange-500 shadow-lg shadow-orange-500/10 scale-[1.02]' : 'bg-gray-800 border-gray-700 hover:border-gray-600 hover:bg-gray-700/50' %>"
                  data-action="click->scouting#selectClimb"
                  data-climb-card
                  data-level="<%= level %>"
                  role="radio"
                  aria-checked="<%= is_selected %>"
                  aria-label="<%= level %> climb - <%= points %> points">
            <p class="text-lg font-bold <%= is_selected ? 'text-orange-400' : 'text-gray-300' %>"><%= level %></p>
            <p class="text-xs text-gray-500"><%= points %> pts</p>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== NOTES ===== %>
  <div class="mt-4">
    <div class="scout-card p-4">
      <%= f.label :notes, class: "block text-xs text-gray-400 uppercase tracking-wider mb-2 font-medium" %>
      <%= f.text_area :notes, rows: 3, class: "input-field text-sm resize-none", placeholder: "Defense quality, robot issues, strategy observations..." %>
    </div>
  </div>

  <%# ===== SUBMIT ===== %>
  <div class="mt-4 pb-4">
    <%= f.submit scouting_entry.persisted? ? "Update Entry" : "Submit Entry",
                 class: "w-full py-4 text-lg font-bold bg-orange-600 hover:bg-orange-500 active:bg-orange-700 text-white rounded-xl transition-all duration-150 active:scale-[0.98] cursor-pointer shadow-lg shadow-orange-500/20 hover:shadow-orange-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950" %>
  </div>
<% end %>
