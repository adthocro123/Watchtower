<%# Turbo Stream / broadcast partial for a single scouting entry %>
<%= link_to scouting_entry_path(scouting_entry),
    id: dom_id(scouting_entry),
    class: "flex items-center justify-between px-4 sm:px-6 py-3 hover:bg-gray-800/30 transition-colors duration-150 border-b border-gray-800/50 last:border-b-0 group",
    role: "listitem",
    "aria-label": "Entry for Team #{scouting_entry.frc_team.team_number}#{scouting_entry.match ? " - #{scouting_entry.match.display_name}" : ''}" do %>
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-gray-700/70 transition-colors duration-150">
      <span class="text-sm font-bold text-orange-400 font-mono"><%= scouting_entry.frc_team.team_number %></span>
    </div>
    <div class="min-w-0">
      <p class="text-sm font-medium text-white group-hover:text-orange-400 transition-colors duration-150">
        <% if scouting_entry.match %>
          <%= scouting_entry.match.display_name %>
        <% else %>
          Team <%= scouting_entry.frc_team.team_number %>
        <% end %>
      </p>
      <p class="text-xs text-gray-500 truncate">
        <%= scouting_entry.user.full_name %> &middot; <%= scouting_entry.mode_label %> &middot; <%= time_ago_in_words(scouting_entry.created_at) %> ago
      </p>
    </div>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <div class="text-right">
      <p class="text-sm font-bold text-white font-mono"><%= scouting_entry.total_points %> pts</p>
      <% unless scouting_entry.submitted? %>
        <span class="<%= case scouting_entry.status
            when 'flagged' then 'badge-amber'
            when 'rejected' then 'badge-red'
            else 'badge-gray'
            end %> text-[10px]">
          <%= scouting_entry.flagged? ? "Inaccurate" : scouting_entry.status&.capitalize %>
        </span>
      <% end %>
    </div>
    <svg class="w-4 h-4 text-gray-600 group-hover:text-gray-400 transition-colors duration-150" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
<% end %>
