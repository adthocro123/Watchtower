<% content_for(:title) { "Edit Entry - ScoutRail" } %>

<div class="max-w-lg mx-auto">
  <div class="flex items-center gap-2 mb-4">
    <%= link_to scouting_entry_path(@scouting_entry), class: "text-gray-500 hover:text-gray-300 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-xl font-bold text-white">Edit Entry</h1>
    <span class="text-xs text-gray-500 ml-auto">Team <%= @scouting_entry.frc_team.team_number %></span>
  </div>

  <%= render "form", scouting_entry: @scouting_entry %>
</div>
