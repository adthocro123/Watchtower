<% content_for(:title) { "Data Conflicts - Watchtower" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Data Conflicts</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @data_conflicts.count %> unresolved conflicts at <%= current_event.name %></p>
  </div>
</div>

<% if @data_conflicts.any? %>
  <div class="space-y-4">
    <% @data_conflicts.each do |conflict| %>
      <div class="scout-card overflow-hidden">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <div>
            <h3 class="font-semibold text-white">
              Team
              <span class="text-orange-400 font-mono"><%= conflict.frc_team.team_number %></span>
              &middot;
              <span class="text-gray-400"><%= conflict.match.display_name %></span>
            </h3>
            <p class="text-xs text-gray-500 mt-0.5">
              Field: <span class="text-amber-400 font-mono"><%= conflict.field_name %></span>
              &middot; Detected <%= time_ago_in_words(conflict.created_at) %> ago
            </p>
          </div>
          <span class="badge-amber shrink-0">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.27 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            Unresolved
          </span>
        </div>

        <%# Conflicting Values %>
        <div class="px-4 sm:px-6 py-4">
          <p class="text-xs text-gray-400 uppercase tracking-wider mb-3 font-medium">Conflicting Values from Scouts</p>
          <% entries_by_user = conflict.conflicting_entries.index_by(&:user_id) %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-4">
            <% (conflict.values || {}).each do |scout_id, value| %>
              <% scout = User.find_by(id: scout_id) %>
              <% entry = entries_by_user[scout_id.to_i] %>
              <div class="bg-gray-800 rounded-lg p-3 border border-gray-700 hover:border-gray-600 transition-colors duration-150 group">
                <div class="flex items-center justify-between gap-2 mb-1">
                  <p class="text-xs text-gray-500"><%= scout&.full_name || "Scout ##{scout_id}" %></p>
                  <% if entry %>
                    <span class="<%= entry.status_badge_class %> text-[10px]"><%= entry.status_label %></span>
                  <% end %>
                </div>
                <p class="text-lg font-bold text-white font-mono"><%= value %></p>
                <% if entry %>
                  <p class="mt-1 text-xs text-gray-500"><%= entry.total_points %> pts &middot; <%= link_to "View entry", scouting_entry_path(entry), class: "text-orange-400 hover:text-orange-300" %></p>
                <% end %>
                <%# Quick-select button %>
                <div class="mt-2 grid grid-cols-1 gap-2 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity duration-150">
                  <button type="button"
                          class="w-full text-xs py-1.5 px-2 rounded-md bg-gray-700 hover:bg-orange-500/20 text-gray-400 hover:text-orange-400 transition-all duration-150 font-medium"
                          onclick="this.closest('.scout-card').querySelector('input[name=resolution]').value = '<%= j(value.to_s) %>'; this.closest('.scout-card').querySelector('select[name=approved_entry_id]').value = ''">
                    Use this value
                  </button>
                  <% if entry&.flagged? %>
                    <button type="button"
                            class="w-full text-xs py-1.5 px-2 rounded-md bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-300 transition-all duration-150 font-medium"
                            onclick="this.closest('.scout-card').querySelector('input[name=resolution]').value = '<%= j(value.to_s) %>'; this.closest('.scout-card').querySelector('select[name=approved_entry_id]').value = '<%= entry.id %>'">
                      Use and approve this scout
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Resolve Form %>
          <%= form_with url: resolve_data_conflict_path(conflict), method: :post, class: "grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_18rem_auto] gap-3 items-end", data: { controller: "offline-guard", action: "submit->offline-guard#check" } do %>
            <div>
              <label for="resolution_<%= conflict.id %>" class="block text-xs text-gray-400 mb-1 font-medium">Resolved Value</label>
              <input type="text" name="resolution" id="resolution_<%= conflict.id %>" required
                     class="input-field text-sm font-mono"
                     placeholder="Enter the correct value...">
              <p class="mt-1 text-xs text-gray-600">This value is written back into the conflicting scouting entries for this team and match.</p>
            </div>

            <div>
              <label for="approved_entry_<%= conflict.id %>" class="block text-xs text-gray-400 mb-1 font-medium">Optional Admin Approval</label>
              <select name="approved_entry_id" id="approved_entry_<%= conflict.id %>" class="input-field text-sm">
                <option value="">Do not approve a scout entry</option>
                <% entries_by_user.each_value.select(&:flagged?).each do |entry| %>
                  <option value="<%= entry.id %>"><%= entry.user.full_name %> &middot; Team <%= entry.frc_team.team_number %></option>
                <% end %>
              </select>
              <p class="mt-1 text-xs text-gray-600">Use this when a flagged entry should still count as valid scouting coverage.</p>
            </div>

            <button type="submit" class="btn-primary whitespace-nowrap">
              Resolve Conflict
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 scout-card">
    <svg class="w-12 h-12 text-orange-500/50 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p class="text-gray-400 font-medium">No Data Conflicts</p>
    <p class="text-gray-600 text-sm mt-1">All scouting data is consistent.</p>
  </div>
<% end %>
