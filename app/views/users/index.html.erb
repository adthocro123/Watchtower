<% content_for(:title) { "Users - Watchtower" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Users</h1>
    <p class="text-sm text-gray-400 mt-1">Manage team accounts and roles</p>
  </div>
  <%= link_to new_user_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    <span class="hidden sm:inline ml-1.5">Add User</span>
  <% end %>
</div>

<div class="overflow-x-auto rounded-xl border border-gray-800 bg-gray-900/50">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-800 text-left text-xs text-gray-500 uppercase tracking-wider">
        <th class="px-4 py-3 font-medium">Name</th>
        <th class="px-4 py-3 font-medium">Role</th>
        <th class="px-4 py-3 font-medium text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800/50">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-800/30 transition-colors duration-150">
          <td class="px-4 py-3">
            <span class="font-medium text-white"><%= user.full_name %></span>
            <% if user == current_user %>
              <span class="text-xs text-gray-500 ml-1">(you)</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <% case user.role %>
            <% when "admin" %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-orange-500/10 text-orange-400 ring-1 ring-inset ring-orange-500/20">Admin</span>
            <% when "analyst" %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-blue-500/10 text-blue-400 ring-1 ring-inset ring-blue-500/20">Analyst</span>
            <% when "scout" %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-gray-500/10 text-gray-400 ring-1 ring-inset ring-gray-500/20">Scout</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to edit_user_path(user), class: "text-gray-400 hover:text-white transition-colors duration-150 p-1 rounded hover:bg-gray-800", title: "Edit" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              <% end %>
              <% if user != current_user %>
                <%= button_to user_path(user), method: :delete, class: "text-gray-400 hover:text-red-400 transition-colors duration-150 p-1 rounded hover:bg-gray-800", title: "Delete", data: { turbo_confirm: "Delete #{user.full_name}?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @users.empty? %>
  <div class="text-center py-16">
    <p class="text-gray-500 font-medium mb-1">No users found</p>
  </div>
<% end %>
