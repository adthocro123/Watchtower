<% content_for(:title) { "#{@pick_list.name} - Lighthouse" } %>

<div class="max-w-5xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to pick_lists_path, class: "back-link", "aria-label": "Back to pick lists" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white flex-1"><%= @pick_list.name %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_pick_list_path(@pick_list), class: "btn-secondary text-sm" %>
      <%= button_to "Delete", pick_list_path(@pick_list), method: :delete, data: { turbo_confirm: "Delete this pick list?" }, class: "btn-danger text-sm", form: { data: { controller: "offline-guard", action: "submit->offline-guard#check" } } %>
    </div>
  </div>

  <p class="text-sm text-gray-500 mb-4">By <%= @pick_list.user.full_name %> &middot; <%= @pick_list.team_count %> teams &middot; Updated <%= time_ago_in_words(@pick_list.updated_at) %> ago</p>

  <%# Tier Legend %>
  <div class="flex flex-wrap items-center gap-4 mb-4 text-xs text-gray-500">
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-amber-400 rounded-full"></span> Tier 1 (Top 8)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-orange-400 rounded-full"></span> Tier 2 (9-16)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-blue-400 rounded-full"></span> Tier 3 (17-24)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-gray-500 rounded-full"></span> Tier 4 (25+)</span>
  </div>

  <div data-controller="sortable pick-list-board"
       data-pick-list-board-storage-key-value="pick-list:<%= @pick_list.id %>:picked"
       data-sortable-save-url="<%= pick_list_path(@pick_list) %>">
    <div class="mb-4 rounded-xl border border-gray-800 bg-gray-950/50 px-4 py-3 flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold text-white">Draft Board Tools</h2>
        <p class="text-xs text-gray-500 mt-1">Drag rows, use the arrow buttons, or sort by stats. Mark teams as picked to gray them out locally.</p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <select class="input-field text-sm min-w-48"
                aria-label="Sort pick list"
                data-action="change->sortable#sortBy">
          <option value="avgPoints">Sort by avg points</option>
          <option value="avgAccuracy">Sort by avg accuracy</option>
          <option value="recentPoints">Sort by recent points</option>
          <option value="recentAccuracy">Sort by recent accuracy</option>
          <option value="defense">Sort by defense</option>
          <option value="teamNumber">Sort by team number</option>
        </select>
        <span class="badge-gray text-xs" data-pick-list-board-target="pickedCount">0 picked</span>
        <button type="button" class="btn-secondary text-sm" data-pick-list-board-target="hidePickedLabel" data-action="click->pick-list-board#toggleHidePicked">Hide picked</button>
      </div>
    </div>

    <%# Drag-and-drop sortable list %>
    <div class="scout-card overflow-hidden">
    <div data-sortable-target="list" data-action="dragover->sortable#dragover drop->sortable#drop" class="divide-y divide-gray-800/50">
      <% entries = @ordered_team_ids %>
      <% if entries.any? %>
        <% entries.each_with_index do |team_id, idx| %>
          <% team = @teams_by_id[team_id.to_i] %>
          <% next unless team %>
          <% summary = @team_summaries[team.id] %>
          <% recent_entry = @latest_entries_by_team[team.id] %>
          <% avg_points = summary.try(:avg_total_points).to_f.round(1) %>
          <% avg_accuracy = summary.try(:fuel_accuracy_pct).to_f.round(1) %>
          <% avg_defense = summary.try(:avg_defense_rating) %>
          <% matches_scouted = summary.try(:matches_scouted).to_i %>
          <% recent_points = recent_entry&.points.to_f.round(1) %>
          <% recent_accuracy = recent_entry&.accuracy.to_f.round(1) %>
          <% recent_match = recent_entry&.match_label %>
          <% tier_color = case idx
                          when 0..7 then "amber"
                          when 8..15 then "orange"
                          when 16..23 then "blue"
                          else "gray"
                          end %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-800/30 transition-all duration-150 cursor-grab active:cursor-grabbing select-none"
                data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend"
                data-sortable-target="item"
                data-pick-list-board-target="item"
                data-sortable-id="<%= team.id %>"
                data-team-number="<%= team.team_number %>"
                data-avg-points="<%= avg_points %>"
                data-avg-accuracy="<%= avg_accuracy %>"
                data-recent-points="<%= recent_points %>"
                data-recent-accuracy="<%= recent_accuracy %>"
                data-defense="<%= avg_defense.to_f.round(1) %>"
                role="listitem"
                aria-label="Rank <%= idx + 1 %>: Team <%= team.team_number %> - <%= team.nickname %>">
            <%# Drag handle %>
            <div class="text-gray-600 shrink-0 touch-none" aria-label="Drag to reorder" data-sortable-handle>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
              </svg>
            </div>
            <%# Rank number with tier color (updated dynamically) %>
            <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold font-mono shrink-0
              <%= case tier_color
                  when 'amber' then 'bg-amber-500/20 border border-amber-500/30 text-amber-400'
                  when 'orange' then 'bg-orange-500/20 border border-orange-500/30 text-orange-400'
                  when 'blue' then 'bg-blue-500/20 border border-blue-500/30 text-blue-400'
                  else 'bg-gray-500/20 border border-gray-500/30 text-gray-400'
                  end %>"
              data-sortable-target="rank">
              <%= idx + 1 %>
            </span>
            <%# Team info %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-bold text-orange-400 font-mono"><%= team.team_number %></span>
                <span class="text-gray-400 text-sm truncate"><%= team.nickname %></span>
              </div>
              <% if summary %>
                <div class="flex items-center gap-3 mt-0.5">
                  <span class="text-xs text-gray-500"><%= avg_points %> avg pts</span>
                  <span class="text-xs text-gray-600">&middot;</span>
                  <span class="text-xs text-gray-500"><%= avg_accuracy %>% acc</span>
                  <span class="text-xs text-gray-600">&middot;</span>
                  <% if avg_defense.present? %>
                    <span class="text-xs text-blue-400"><%= avg_defense.to_f.round(1) %>/5 def</span>
                    <span class="text-xs text-gray-600">&middot;</span>
                  <% end %>
                  <span class="text-xs text-gray-500"><%= matches_scouted %> matches</span>
                </div>
              <% end %>

              <div class="flex flex-wrap items-center gap-3 mt-1 text-xs text-gray-600">
                <% if recent_entry %>
                  <span>Latest <%= recent_match || "entry" %></span>
                  <span><%= recent_points %> pts</span>
                  <span><%= recent_accuracy %>% acc</span>
                <% else %>
                  <span>No recent entry yet</span>
                <% end %>
              </div>
            </div>
            <%# Avg Points Badge %>
            <% if summary %>
              <div class="text-right shrink-0 hidden sm:block">
                <p class="text-sm font-mono font-bold text-white"><%= avg_points %></p>
                <p class="text-[10px] text-gray-600">avg pts</p>
              </div>
            <% end %>
            <div class="flex items-center gap-2 shrink-0">
              <button type="button" class="rounded-lg p-2 text-gray-400 hover:text-orange-300 hover:bg-gray-800 transition-colors duration-150" data-action="click->sortable#moveUp" aria-label="Move team up">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
              </button>
              <button type="button" class="rounded-lg p-2 text-gray-400 hover:text-orange-300 hover:bg-gray-800 transition-colors duration-150" data-action="click->sortable#moveDown" aria-label="Move team down">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <button type="button"
                      class="rounded-lg px-3 py-1.5 text-xs font-semibold bg-gray-800 text-gray-300 border border-gray-700 hover:border-emerald-500/30 hover:text-emerald-300 transition-colors duration-150"
                      data-pick-list-board-target="toggle"
                      data-team-id="<%= team.id %>"
                      data-action="click->pick-list-board#toggle">
                Mark picked
              </button>
            </div>
            <%# View link %>
            <%= link_to team_path(team), class: "text-gray-600 hover:text-gray-400 transition-colors duration-150 shrink-0 p-1 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500", "aria-label": "View team #{team.team_number}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12 px-4">
          <svg class="w-10 h-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
          <p class="text-gray-500 text-sm font-medium mb-1">No teams in this pick list yet</p>
          <p class="text-gray-600 text-xs">Edit the pick list to add teams.</p>
        </div>
      <% end %>
    </div>
  </div>
  </div>
</div>
