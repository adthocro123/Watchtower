<% content_for(:title) { "#{@pick_list.name} - ScoutRail" } %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to pick_lists_path, class: "back-link", "aria-label": "Back to pick lists" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white flex-1"><%= @pick_list.name %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_pick_list_path(@pick_list), class: "btn-secondary text-sm" %>
      <%= button_to "Delete", pick_list_path(@pick_list), method: :delete, data: { turbo_confirm: "Delete this pick list?" }, class: "btn-danger text-sm" %>
    </div>
  </div>

  <p class="text-sm text-gray-500 mb-4">By <%= @pick_list.user.full_name %> &middot; Updated <%= time_ago_in_words(@pick_list.updated_at) %> ago</p>

  <%# Drag-and-drop sortable list %>
  <div class="scout-card overflow-hidden"
       data-controller="sortable"
       data-sortable-save-url="<%= pick_list_path(@pick_list) %>">
    <div data-sortable-target="list" class="divide-y divide-gray-800/50">
      <% entries = @pick_list.entries || [] %>
      <% if entries.any? %>
        <% teams = FrcTeam.where(id: entries).index_by(&:id) %>
        <% entries.each_with_index do |team_id, idx| %>
          <% team = teams[team_id.to_i] %>
          <% next unless team %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-800/30 transition-all duration-150 cursor-grab active:cursor-grabbing select-none"
               data-sortable-target="item"
               data-sortable-id="<%= team.id %>"
               role="listitem"
               aria-label="Rank <%= idx + 1 %>: Team <%= team.team_number %> - <%= team.nickname %>">
            <%# Drag handle %>
            <div class="text-gray-600 shrink-0 touch-none" aria-label="Drag to reorder" data-sortable-handle>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
              </svg>
            </div>
            <%# Rank number (updated dynamically) %>
            <span class="w-8 h-8 bg-gray-800 rounded-lg flex items-center justify-center text-sm font-bold text-gray-400 font-mono shrink-0" data-sortable-target="rank">
              <%= idx + 1 %>
            </span>
            <%# Team info %>
            <div class="flex-1 min-w-0">
              <span class="font-bold text-emerald-400 font-mono"><%= team.team_number %></span>
              <span class="text-gray-400 text-sm ml-1.5"><%= team.nickname %></span>
            </div>
            <%# View link %>
            <%= link_to team_path(team), class: "text-gray-600 hover:text-gray-400 transition-colors duration-150 shrink-0 p-1 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500", "aria-label": "View team #{team.team_number}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12 px-4">
          <svg class="w-10 h-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
          <p class="text-gray-500 text-sm font-medium mb-1">No teams in this pick list yet</p>
          <p class="text-gray-600 text-xs">Edit the pick list to add teams.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
