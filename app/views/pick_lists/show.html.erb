<% content_for(:title) { "#{@pick_list.name} - Lighthouse" } %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to pick_lists_path, class: "back-link", "aria-label": "Back to pick lists" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white flex-1"><%= @pick_list.name %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_pick_list_path(@pick_list), class: "btn-secondary text-sm" %>
      <%= button_to "Delete", pick_list_path(@pick_list), method: :delete, data: { turbo_confirm: "Delete this pick list?" }, class: "btn-danger text-sm", form: { data: { controller: "offline-guard", action: "submit->offline-guard#check" } } %>
    </div>
  </div>

  <p class="text-sm text-gray-500 mb-4">By <%= @pick_list.user.full_name %> &middot; <%= @pick_list.team_count %> teams &middot; Updated <%= time_ago_in_words(@pick_list.updated_at) %> ago</p>

  <%# Tier Legend %>
  <div class="flex items-center gap-4 mb-4 text-xs text-gray-500">
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-amber-400 rounded-full"></span> Tier 1 (Top 8)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-orange-400 rounded-full"></span> Tier 2 (9-16)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-blue-400 rounded-full"></span> Tier 3 (17-24)</span>
    <span class="flex items-center gap-1"><span class="w-2 h-2 bg-gray-500 rounded-full"></span> Tier 4 (25+)</span>
  </div>

  <%# Drag-and-drop sortable list %>
  <div class="scout-card overflow-hidden"
       data-controller="sortable"
       data-sortable-save-url="<%= pick_list_path(@pick_list) %>">
    <div data-sortable-target="list" class="divide-y divide-gray-800/50">
      <% entries = @pick_list.ordered_team_ids %>
      <% if entries.any? %>
        <% teams = FrcTeam.where(id: entries).index_by(&:id) %>
        <% summaries = TeamEventSummary.where(event: current_event, frc_team_id: entries).index_by(&:frc_team_id) %>
        <% entries.each_with_index do |team_id, idx| %>
          <% team = teams[team_id.to_i] %>
          <% next unless team %>
          <% summary = summaries[team.id] %>
          <% tier_color = case idx
                          when 0..7 then "amber"
                          when 8..15 then "orange"
                          when 16..23 then "blue"
                          else "gray"
                          end %>
          <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-800/30 transition-all duration-150 cursor-grab active:cursor-grabbing select-none"
               data-sortable-target="item"
               data-sortable-id="<%= team.id %>"
               role="listitem"
               aria-label="Rank <%= idx + 1 %>: Team <%= team.team_number %> - <%= team.nickname %>">
            <%# Drag handle %>
            <div class="text-gray-600 shrink-0 touch-none" aria-label="Drag to reorder" data-sortable-handle>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
              </svg>
            </div>
            <%# Rank number with tier color (updated dynamically) %>
            <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold font-mono shrink-0
              <%= case tier_color
                  when 'amber' then 'bg-amber-500/20 border border-amber-500/30 text-amber-400'
                  when 'orange' then 'bg-orange-500/20 border border-orange-500/30 text-orange-400'
                  when 'blue' then 'bg-blue-500/20 border border-blue-500/30 text-blue-400'
                  else 'bg-gray-500/20 border border-gray-500/30 text-gray-400'
                  end %>"
              data-sortable-target="rank">
              <%= idx + 1 %>
            </span>
            <%# Team info %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-bold text-orange-400 font-mono"><%= team.team_number %></span>
                <span class="text-gray-400 text-sm truncate"><%= team.nickname %></span>
              </div>
              <% if summary %>
                <div class="flex items-center gap-3 mt-0.5">
                  <span class="text-xs text-gray-500"><%= summary.avg_total_points.to_f.round(1) %> avg pts</span>
                  <span class="text-xs text-gray-600">&middot;</span>
                  <span class="text-xs text-gray-500"><%= summary.fuel_accuracy_pct.to_f.round(0) %>% acc</span>
                  <span class="text-xs text-gray-600">&middot;</span>
                  <% if summary.avg_defense_rating.present? %>
                    <span class="text-xs text-blue-400"><%= summary.avg_defense_rating.to_f.round(1) %>/5 def</span>
                    <span class="text-xs text-gray-600">&middot;</span>
                  <% end %>
                  <span class="text-xs text-gray-500"><%= summary.matches_scouted %> matches</span>
                </div>
              <% end %>
            </div>
            <%# Avg Points Badge %>
            <% if summary %>
              <div class="text-right shrink-0 hidden sm:block">
                <p class="text-sm font-mono font-bold text-white"><%= summary.avg_total_points.to_f.round(1) %></p>
                <p class="text-[10px] text-gray-600">avg pts</p>
              </div>
            <% end %>
            <%# View link %>
            <%= link_to team_path(team), class: "text-gray-600 hover:text-gray-400 transition-colors duration-150 shrink-0 p-1 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500", "aria-label": "View team #{team.team_number}" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12 px-4">
          <svg class="w-10 h-10 text-gray-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
          <p class="text-gray-500 text-sm font-medium mb-1">No teams in this pick list yet</p>
          <p class="text-gray-600 text-xs">Edit the pick list to add teams.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
