<% content_for(:title) { "Edit #{@pick_list.name} - Lighthouse" } %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to pick_list_path(@pick_list), class: "back-link", "aria-label": "Back to pick list" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white">Edit Pick List</h1>
  </div>

  <div class="scout-card p-5 sm:p-6">
    <%= render "form", pick_list: @pick_list %>
  </div>
</div>
