<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950 border-b border-gray-800 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <%# Logo / Brand %>
      <%= link_to root_path, class: "flex items-center gap-2 shrink-0" do %>
        <div class="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <span class="text-lg font-bold text-white tracking-tight hidden sm:block">ScoutRail</span>
      <% end %>

      <%# Current Event Selector %>
      <% if user_signed_in? && current_event %>
        <div class="hidden sm:flex items-center gap-2 text-sm">
          <span class="text-gray-400">Event:</span>
          <span class="text-emerald-400 font-semibold truncate max-w-48"><%= current_event.name %></span>
          <%= link_to "Change", events_path, class: "text-xs text-gray-500 hover:text-gray-300 transition" %>
        </div>
      <% end %>

      <%# User Menu %>
      <% if user_signed_in? %>
        <div class="flex items-center gap-3">
          <%# Desktop nav links %>
          <div class="hidden md:flex items-center gap-1">
            <%= link_to "Scout", new_scouting_entry_path, class: "px-3 py-1.5 text-sm rounded-md transition #{request.path.include?('scouting_entries') ? 'bg-emerald-500/20 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" if current_event %>
            <%= link_to "Teams", teams_path, class: "px-3 py-1.5 text-sm rounded-md transition #{request.path.include?('teams') ? 'bg-emerald-500/20 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" if current_event %>
            <%= link_to "Entries", scouting_entries_path, class: "px-3 py-1.5 text-sm rounded-md transition #{request.path == scouting_entries_path ? 'bg-emerald-500/20 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" if current_event %>
            <%= link_to "Pick List", pick_lists_path, class: "px-3 py-1.5 text-sm rounded-md transition #{request.path.include?('pick_list') ? 'bg-emerald-500/20 text-emerald-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}" if current_event %>
          </div>

          <%# Role badge + user %>
          <div class="flex items-center gap-2">
            <% role = current_user.role_name %>
            <span class="hidden sm:inline-block text-xs font-medium px-2 py-0.5 rounded-full
              <%= case role
                  when 'admin' then 'bg-red-500/20 text-red-400 border border-red-500/30'
                  when 'lead' then 'bg-amber-500/20 text-amber-400 border border-amber-500/30'
                  when 'analyst' then 'bg-blue-500/20 text-blue-400 border border-blue-500/30'
                  else 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
                  end %>">
              <%= role.capitalize %>
            </span>
            <span class="text-sm text-gray-300 hidden sm:block"><%= current_user.first_name %></span>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "text-gray-500 hover:text-red-400 transition p-1" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="flex items-center gap-2">
          <%= link_to "Sign In", new_user_session_path, class: "px-3 py-1.5 text-sm text-gray-300 hover:text-white transition" %>
          <%= link_to "Sign Up", new_user_registration_path, class: "px-3 py-1.5 text-sm bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg transition" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
