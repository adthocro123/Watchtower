<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-950/95 backdrop-blur-sm border-b border-gray-800 shadow-lg" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <%# Logo / Brand %>
      <%= link_to root_path, class: "flex items-center gap-2 shrink-0 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950", "aria-label": "Watchtower home" do %>
        <%= image_tag "132-1323745_petoskey-paladins-blue-png-petoskey-paladins.png", alt: "Watchtower", class: "w-8 h-8 rounded-lg object-contain" %>
        <span class="text-lg font-bold text-white tracking-tight hidden sm:block">Watchtower</span>
      <% end %>

      <%# Current Event + Org %>
      <% if user_signed_in? && current_event %>
        <div class="hidden sm:flex items-center gap-2 text-sm">
          <%= link_to events_path, class: "inline-flex items-center gap-1.5 text-orange-400 font-semibold tracking-wide hover:text-orange-300 transition-colors duration-150 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500", title: "Switch event" do %>
            <%= current_event.tba_key&.upcase || current_event.name %>
            <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
            </svg>
          <% end %>
        </div>
      <% end %>

      <%# User Menu %>
      <% if user_signed_in? %>
        <div class="flex items-center gap-3">
          <%# Desktop nav links - fix mutual exclusion for Scout vs Entries %>
          <% if current_event %>
            <div class="hidden md:flex items-center gap-1">
              <%
                is_new_entry = request.path == new_scouting_entry_path
                is_edit_entry = request.path.match?(/scouting_entries\/\d+\/edit/)
                is_entries_index = request.path == scouting_entries_path
                is_entry_show = request.path.match?(/scouting_entries\/\d+$/) && !request.path.include?('pit_scouting')
                is_scout_active = is_new_entry || is_edit_entry
                is_entries_active = is_entries_index || is_entry_show
              %>
              <%= link_to "Scout", new_scouting_entry_path,
                class: "nav-link #{is_scout_active ? 'nav-link-active' : 'nav-link-inactive'}",
                "aria-current": (is_scout_active ? "page" : nil) %>
              <%= link_to "Pit", pit_scouting_entries_path,
                class: "nav-link #{request.path.include?('pit_scouting') ? 'nav-link-active' : 'nav-link-inactive'}",
                "aria-current": (request.path.include?('pit_scouting') ? "page" : nil) %>
              <%= link_to "Teams", teams_path,
                class: "nav-link #{request.path.include?('teams') ? 'nav-link-active' : 'nav-link-inactive'}",
                "aria-current": (request.path.include?('teams') ? "page" : nil) %>
              <% if current_user.admin? %>
                <%= link_to "Online", online_users_path,
                  class: "nav-link #{request.path == online_users_path ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path == online_users_path ? "page" : nil) %>
              <% end %>
              <% if current_user.admin? || current_user.analyst? %>
                <%= link_to "Compare", team_comparison_path,
                  class: "nav-link #{request.path.include?('comparison') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('comparison') ? "page" : nil) %>
                <%= link_to "Predict", predictions_path,
                  class: "nav-link #{request.path.include?('prediction') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('prediction') ? "page" : nil) %>
                <%= link_to "Simulate", new_match_simulator_path,
                  class: "nav-link #{request.path.include?('simulator') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('simulator') ? "page" : nil) %>
                <%= link_to "Picks", pick_lists_path,
                  class: "nav-link #{request.path.include?('pick_list') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('pick_list') ? "page" : nil) %>
              <% end %>
              <% if current_user.admin? %>
                <%= link_to "Schedule", scouting_assignments_path,
                  class: "nav-link #{request.path.include?('scouting_assignments') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('scouting_assignments') ? "page" : nil) %>
              <% else %>
                <%= link_to "My Schedule", scouting_assignments_path,
                  class: "nav-link #{request.path.include?('scouting_assignments') ? 'nav-link-active' : 'nav-link-inactive'}",
                  "aria-current": (request.path.include?('scouting_assignments') ? "page" : nil) %>
              <% end %>
              <%= link_to "Entries", scouting_entries_path,
                class: "nav-link #{is_entries_active ? 'nav-link-active' : 'nav-link-inactive'}",
                "aria-current": (is_entries_active ? "page" : nil) %>
            </div>
          <% end %>

          <% if current_user.admin? %>
            <%= link_to users_path, class: "text-gray-400 hover:text-white transition-colors duration-150 p-1.5 rounded-lg hover:bg-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950", title: "Manage Users", "aria-label": "Manage Users" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            <% end %>
          <% end %>

          <div class="flex items-center gap-2">
            <%= link_to destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "text-gray-400 hover:text-red-400 transition-colors duration-150 p-1.5 rounded-lg hover:bg-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950",
              "aria-label": "Sign out" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="flex items-center gap-2">
          <%= link_to "Sign In", new_user_session_path, class: "btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
