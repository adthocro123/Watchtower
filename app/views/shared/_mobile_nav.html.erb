<% if user_signed_in? && current_event %>
  <nav class="fixed bottom-0 left-0 right-0 z-50 bg-gray-950/95 backdrop-blur-sm border-t border-gray-800 md:hidden safe-area-bottom" aria-label="Mobile navigation">
    <div class="flex items-center justify-around h-16 px-2">
      <%# Dashboard (Home - first position) %>
      <% dashboard_active = request.path == '/' %>
      <%= link_to root_path,
        class: "flex flex-col items-center gap-0.5 py-1 px-3 rounded-lg transition-all duration-150 relative #{dashboard_active ? 'text-emerald-400' : 'text-gray-500 hover:text-gray-300'}",
        "aria-label": "Dashboard",
        "aria-current": (dashboard_active ? "page" : nil) do %>
        <% if dashboard_active %><span class="absolute -top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-emerald-400 rounded-full"></span><% end %>
        <svg class="w-6 h-6" fill="<%= dashboard_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        <span class="text-xs font-medium">Dashboard</span>
      <% end %>

      <%# Scout %>
      <% scout_active = request.path == new_scouting_entry_path %>
      <%= link_to new_scouting_entry_path,
        class: "flex flex-col items-center gap-0.5 py-1 px-3 rounded-lg transition-all duration-150 relative #{scout_active ? 'text-emerald-400' : 'text-gray-500 hover:text-gray-300'}",
        "aria-label": "Scout a match",
        "aria-current": (scout_active ? "page" : nil) do %>
        <% if scout_active %><span class="absolute -top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-emerald-400 rounded-full"></span><% end %>
        <svg class="w-6 h-6" fill="<%= scout_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        <span class="text-xs font-medium">Scout</span>
      <% end %>

      <%# Teams %>
      <% teams_active = request.path.include?('teams') %>
      <%= link_to teams_path,
        class: "flex flex-col items-center gap-0.5 py-1 px-3 rounded-lg transition-all duration-150 relative #{teams_active ? 'text-emerald-400' : 'text-gray-500 hover:text-gray-300'}",
        "aria-label": "Team rankings",
        "aria-current": (teams_active ? "page" : nil) do %>
        <% if teams_active %><span class="absolute -top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-emerald-400 rounded-full"></span><% end %>
        <svg class="w-6 h-6" fill="<%= teams_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="text-xs font-medium">Teams</span>
      <% end %>

      <%# Entries %>
      <% entries_active = request.path == scouting_entries_path || request.path.match?(/scouting_entries\/\d+$/) %>
      <%= link_to scouting_entries_path,
        class: "flex flex-col items-center gap-0.5 py-1 px-3 rounded-lg transition-all duration-150 relative #{entries_active ? 'text-emerald-400' : 'text-gray-500 hover:text-gray-300'}",
        "aria-label": "Scouting entries",
        "aria-current": (entries_active ? "page" : nil) do %>
        <% if entries_active %><span class="absolute -top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-emerald-400 rounded-full"></span><% end %>
        <svg class="w-6 h-6" fill="<%= entries_active ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span class="text-xs font-medium">Entries</span>
      <% end %>
    </div>
  </nav>
<% end %>
