<% if user_signed_in? && current_event %>
  <%
    # Build the ordered list of nav items for the current user's role.
    # Each item: { label:, path:, active:, icon: (SVG path d attribute), filled_icon: (optional) }
    mobile_nav_items = []

    # --- Core items (all roles) ---
    mobile_nav_items << {
      label: "Home",
      path: root_path,
      active: request.path == "/",
      aria_label: "Dashboard",
      icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
    }

    mobile_nav_items << {
      label: "Scout",
      path: new_scouting_entry_path,
      active: request.path == new_scouting_entry_path || request.path.match?(/scouting_entries\/\d+\/edit/),
      aria_label: "Scout a match",
      icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
    }

    mobile_nav_items << {
      label: "Pit",
      path: pit_scouting_entries_path,
      active: request.path.include?("pit_scouting"),
      aria_label: "Pit scouting",
      icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
    }

    mobile_nav_items << {
      label: "Teams",
      path: teams_path,
      active: request.path.include?("teams"),
      aria_label: "Team rankings",
      icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
    }

    mobile_nav_items << {
      label: "Schedule",
      path: scouting_assignments_path,
      active: request.path.include?("scouting_assignments"),
      aria_label: "Scouting schedule",
      icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
    }

    mobile_nav_items << {
      label: "Entries",
      path: scouting_entries_path,
      active: request.path == scouting_entries_path || (request.path.match?(/scouting_entries\/\d+$/) && !request.path.include?("pit_scouting")),
      aria_label: "Scouting entries",
      icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
    }

    mobile_nav_items << {
      label: "Events",
      path: events_path,
      active: request.path == events_path || request.path.match?(/\/events\/\d+/),
      aria_label: "Switch event",
      icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
    }

    # --- Analyst + Admin items ---
    if current_user.admin? || current_user.analyst?
      mobile_nav_items << {
        label: "Compare",
        path: team_comparison_path,
        active: request.path.include?("comparison"),
        aria_label: "Compare teams",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
      }

      mobile_nav_items << {
        label: "Predict",
        path: predictions_path,
        active: request.path.include?("prediction"),
        aria_label: "Match predictions",
        icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
      }

      mobile_nav_items << {
        label: "Simulate",
        path: new_match_simulator_path,
        active: request.path.include?("simulator"),
        aria_label: "Match simulator",
        icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      }

      mobile_nav_items << {
        label: "Picks",
        path: pick_lists_path,
        active: request.path.include?("pick_list"),
        aria_label: "Pick lists",
        icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
      }
    end

    # --- Admin-only items ---
    if current_user.admin?
      mobile_nav_items << {
        label: "Users",
        path: users_path,
        active: request.path.include?("users"),
        aria_label: "Manage users",
        icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
      }

      mobile_nav_items << {
        label: "Export",
        path: exports_csv_path,
        active: request.path.include?("export"),
        aria_label: "Export data",
        icon: "M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
      }
    end
  %>

  <nav class="fixed bottom-0 left-0 right-0 z-50 bg-gray-950/95 backdrop-blur-sm border-t border-gray-800 lg:hidden safe-area-bottom" aria-label="Mobile navigation">
    <div class="flex items-center justify-around h-16 px-2" data-controller="overflow-nav">

      <%# === Bar items (icon + label, shown inline until they overflow) === %>
      <% mobile_nav_items.each_with_index do |item, i| %>
        <%= link_to item[:path],
          class: "flex flex-col items-center gap-0.5 py-1 px-2 rounded-lg transition-all duration-150 relative #{item[:active] ? 'text-orange-400' : 'text-gray-500 hover:text-gray-300'}",
          "aria-label": item[:aria_label],
          "aria-current": (item[:active] ? "page" : nil),
          data: { overflow_nav_target: "item" } do %>
          <% if item[:active] %><span class="absolute -top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 bg-orange-400 rounded-full"></span><% end %>
          <svg class="w-5 h-5" fill="<%= item[:active] ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>" />
          </svg>
          <span class="text-[10px] font-medium"><%= item[:label] %></span>
        <% end %>
      <% end %>

      <%# === More button + overflow menu === %>
      <details class="relative hidden" id="mobile-more-menu" data-overflow-nav-target="moreButton">
        <summary class="flex flex-col items-center gap-0.5 py-1 px-2 rounded-lg transition-all duration-150 text-gray-500 hover:text-gray-300 cursor-pointer list-none" aria-label="More options">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
          <span class="text-[10px] font-medium">More</span>
        </summary>
        <div class="absolute bottom-full right-0 mb-2 w-48 bg-gray-900 border border-gray-800 rounded-xl shadow-xl overflow-hidden" data-overflow-nav-target="menu">
          <% mobile_nav_items.each_with_index do |item, i| %>
            <%= link_to item[:label], item[:path],
              class: "block px-4 py-3 text-sm transition-colors duration-150 #{item[:active] ? 'text-orange-400 bg-gray-800/50' : 'text-gray-300 hover:bg-gray-800'}",
              data: { overflow_nav_target: "menuItem" } %>
          <% end %>
        </div>
      </details>

    </div>
  </nav>
<% end %>
