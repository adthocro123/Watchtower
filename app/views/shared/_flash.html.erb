<% if notice.present? %>
  <div class="px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 shadow-lg shadow-black/30 text-sm flex items-center gap-2"
       data-controller="flash"
       role="status"
       aria-live="polite">
    <svg class="w-4 h-4 shrink-0 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span class="flex-1 text-gray-200"><%= notice %></span>
    <button type="button" data-action="click->flash#dismiss" class="text-gray-500 hover:text-gray-300 transition p-0.5" aria-label="Dismiss">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
<% end %>

<% if alert.present? %>
  <div class="px-4 py-3 rounded-lg bg-gray-900 border border-red-500/30 shadow-lg shadow-black/30 text-sm flex items-center gap-2"
       data-controller="flash"
       role="alert"
       aria-live="assertive">
    <svg class="w-4 h-4 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.27 16.5c-.77.833.192 2.5 1.732 2.5z" />
    </svg>
    <span class="flex-1 text-red-300"><%= alert %></span>
    <button type="button" data-action="click->flash#dismiss" class="text-gray-500 hover:text-gray-300 transition p-0.5" aria-label="Dismiss">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
<% end %>
