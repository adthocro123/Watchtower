<%= form_with(model: event, class: "space-y-6", data: { controller: "offline-guard", action: "submit->offline-guard#check" }) do |f| %>
  <% if event.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 animate-slide-down" role="alert">
      <h3 class="text-sm font-semibold text-red-400 mb-2"><%= pluralize(event.errors.count, "error") %> prevented this event from being saved:</h3>
      <ul class="text-sm text-red-400/80 list-disc list-inside space-y-1">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if event.persisted? %>
    <%# Edit mode: show all fields %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "input-field", placeholder: "Event name" %>
      </div>

      <div>
        <%= f.label :tba_key, "TBA Key", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :tba_key, class: "input-field font-mono", disabled: true %>
      </div>

      <div>
        <%= f.label :year, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.number_field :year, class: "input-field", disabled: true %>
      </div>

      <div>
        <%= f.label :start_date, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.date_field :start_date, class: "input-field" %>
      </div>

      <div>
        <%= f.label :end_date, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.date_field :end_date, class: "input-field" %>
      </div>

      <div>
        <%= f.label :city, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :city, class: "input-field", placeholder: "City" %>
      </div>

      <div>
        <%= f.label :event_type, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.select :event_type, options_for_select([["Regional", 0], ["District", 1], ["District Championship", 2], ["Championship", 3], ["Offseason", 99]], event.event_type), {}, class: "input-field" %>
      </div>
    </div>
  <% else %>
    <%# New mode: just name, event code, and year — TBA fills the rest %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "input-field", placeholder: "e.g. FIM District Traverse City Event" %>
      </div>

      <div>
        <%= f.label :event_code, "Event Code", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :event_code, class: "input-field font-mono", placeholder: "e.g. mitvc", value: params.dig(:event, :event_code) %>
      </div>

      <div>
        <%= f.label :year, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.number_field :year, class: "input-field", placeholder: Date.current.year, value: event.year || Date.current.year %>
      </div>
    </div>

    <p class="text-xs text-gray-500">Event details (dates, location, type) will be fetched automatically from The Blue Alliance.</p>
  <% end %>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit event.persisted? ? "Update Event" : "Create Event", class: "btn-primary px-6 py-2.5 cursor-pointer" %>
    <%= link_to "Cancel", (event.persisted? ? event_path(event) : events_path), class: "btn-secondary px-6 py-2.5" %>
  </div>
<% end %>
