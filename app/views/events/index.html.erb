<% content_for(:title) { "Events - ScoutRail" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Events</h1>
    <p class="text-sm text-gray-400 mt-1">Select an event or sync from The Blue Alliance</p>
  </div>
  <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
    <%= link_to new_event_path, class: "flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <span class="hidden sm:inline">Add Event</span>
    <% end %>
  <% end %>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @events.each do |event| %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-gray-700 transition group
      <%= 'ring-2 ring-emerald-500/50 border-emerald-500/30' if current_event&.id == event.id %>">
      <div class="p-5">
        <div class="flex items-start justify-between mb-3">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-white truncate"><%= event.name %></h3>
            <p class="text-sm text-gray-400 mt-1">
              <%= event.start_date&.strftime("%b %d") %> - <%= event.end_date&.strftime("%b %d, %Y") %>
            </p>
          </div>
          <% if current_event&.id == event.id %>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 shrink-0 ml-2">Active</span>
          <% end %>
        </div>

        <% if event.city.present? %>
          <p class="text-xs text-gray-500 flex items-center gap-1 mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <%= [event.city, event.state_prov, event.country].compact.join(", ") %>
          </p>
        <% end %>

        <div class="flex items-center gap-2">
          <% if current_event&.id != event.id %>
            <%= button_to "Select", select_event_path(event), method: :post, class: "flex-1 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition text-center" %>
          <% end %>
          <%= link_to "Details", event_path(event), class: "flex-1 px-3 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-lg transition text-center" %>
          <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
            <%= button_to sync_event_path(event), method: :post, class: "p-2 bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-blue-400 rounded-lg transition", title: "Sync from TBA" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @events.empty? %>
  <div class="text-center py-16">
    <svg class="w-12 h-12 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <p class="text-gray-500">No events found.</p>
  </div>
<% end %>
