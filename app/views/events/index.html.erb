<% content_for(:title) { "Events - ScoutRail" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Events</h1>
    <p class="text-sm text-gray-400 mt-1">Select an event or sync from The Blue Alliance</p>
  </div>
  <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
    <%= link_to new_event_path, class: "btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      <span class="hidden sm:inline ml-1.5">Add Event</span>
    <% end %>
  <% end %>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @events.each do |event| %>
    <article class="scout-card-hover overflow-hidden
      <%= 'ring-2 ring-emerald-500/50 border-emerald-500/30' if current_event&.id == event.id %>">
      <div class="p-5">
        <div class="flex items-start justify-between mb-3">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-white truncate"><%= event.name %></h3>
            <p class="text-sm text-gray-400 mt-1">
              <%= event.start_date&.strftime("%b %d") %> - <%= event.end_date&.strftime("%b %d, %Y") %>
            </p>
          </div>
          <% if current_event&.id == event.id %>
            <span class="badge-emerald shrink-0 ml-2">Active</span>
          <% end %>
        </div>

        <% if event.city.present? %>
          <p class="text-xs text-gray-500 flex items-center gap-1 mb-2">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <%= [event.city, event.state_prov, event.country].compact.join(", ") %>
          </p>
        <% end %>

        <%# Team/Entry counts %>
        <div class="flex items-center gap-3 mb-4 text-xs text-gray-500">
          <span class="inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <%= event.frc_teams.count %> teams
          </span>
          <span class="inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <%= event.scouting_entries.count %> entries
          </span>
        </div>

        <div class="flex items-center gap-2">
          <% if current_event&.id != event.id %>
            <%= button_to "Select", select_event_path(event), method: :post, class: "btn-primary flex-1 text-sm" %>
          <% end %>
          <%= link_to "Details", event_path(event), class: "btn-secondary flex-1 text-center text-sm" %>
          <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
            <%= button_to sync_event_path(event), method: :post, class: "btn-ghost p-2", title: "Sync from TBA", "aria-label": "Sync #{event.name} from The Blue Alliance" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>
    </article>
  <% end %>
</div>

<% if @events.empty? %>
  <div class="text-center py-16">
    <svg class="w-12 h-12 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <p class="text-gray-500 font-medium mb-1">No events found</p>
    <p class="text-gray-600 text-sm mb-4">Create an event to start scouting.</p>
    <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
      <%= link_to "Create Event", new_event_path, class: "btn-primary text-sm" %>
    <% end %>
  </div>
<% end %>
