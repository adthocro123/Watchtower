<% content_for(:title) { "#{@event.name} - ScoutRail" } %>

<div class="mb-6">
  <div class="flex items-center gap-2 mb-4">
    <%= link_to events_path, class: "text-gray-500 hover:text-gray-300 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white"><%= @event.name %></h1>
  </div>

  <%# Event Info Card %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Dates</span>
        <p class="text-sm text-white mt-1"><%= @event.start_date&.strftime("%B %d") %> - <%= @event.end_date&.strftime("%B %d, %Y") %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">Location</span>
        <p class="text-sm text-white mt-1"><%= [@event.city, @event.state_prov, @event.country].compact.join(", ").presence || "N/A" %></p>
      </div>
      <div>
        <span class="text-xs text-gray-500 uppercase tracking-wider">TBA Key</span>
        <p class="text-sm text-gray-300 font-mono mt-1"><%= @event.tba_key %></p>
      </div>
    </div>

    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-800">
      <% if current_event&.id != @event.id %>
        <%= button_to "Select Event", select_event_path(@event), method: :post, class: "px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition" %>
      <% else %>
        <span class="px-4 py-2 bg-emerald-500/20 text-emerald-400 text-sm font-medium rounded-lg border border-emerald-500/30">Currently Active</span>
      <% end %>
      <% if current_user.has_role?(:admin) || current_user.has_role?(:lead) %>
        <%= button_to "Sync from TBA", sync_event_path(@event), method: :post, class: "px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-lg transition" %>
        <%= link_to "Edit", edit_event_path(@event), class: "px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-lg transition" %>
      <% end %>
    </div>
  </div>

  <%# Teams at Event %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
      <h2 class="text-lg font-semibold text-white">Teams (<%= @teams.count %>)</h2>
    </div>
    <div class="p-4 sm:p-6">
      <div class="flex flex-wrap gap-2">
        <% @teams.each do |team| %>
          <%= link_to team_path(team), class: "inline-flex items-center gap-1 px-3 py-1.5 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg text-sm transition" do %>
            <span class="font-bold text-emerald-400"><%= team.team_number %></span>
            <% if team.nickname.present? %>
              <span class="text-gray-400 text-xs truncate max-w-24"><%= team.nickname %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
      <% if @teams.empty? %>
        <p class="text-gray-500 text-sm text-center py-4">No teams synced yet. Sync from TBA to import teams.</p>
      <% end %>
    </div>
  </div>

  <%# Matches %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
      <h2 class="text-lg font-semibold text-white">Matches (<%= @matches.count %>)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-gray-500 text-xs uppercase tracking-wider border-b border-gray-800">
            <th class="px-4 py-3 text-left">Match</th>
            <th class="px-4 py-3 text-left">Time</th>
            <th class="px-4 py-3 text-left">Red Alliance</th>
            <th class="px-4 py-3 text-left">Blue Alliance</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800/50">
          <% @matches.each do |match| %>
            <tr class="hover:bg-gray-800/50 transition">
              <td class="px-4 py-3 font-semibold text-white"><%= match.display_name %></td>
              <td class="px-4 py-3 text-gray-400 text-xs"><%= match.scheduled_time&.strftime("%b %d %l:%M %p") || "TBD" %></td>
              <td class="px-4 py-3">
                <div class="flex gap-1.5">
                  <% match.match_alliances.select { |ma| ma.alliance_color == "red" }.sort_by(&:station).each do |ma| %>
                    <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-red-500/20 text-red-400"><%= ma.frc_team.team_number %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="flex gap-1.5">
                  <% match.match_alliances.select { |ma| ma.alliance_color == "blue" }.sort_by(&:station).each do |ma| %>
                    <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-blue-500/20 text-blue-400"><%= ma.frc_team.team_number %></span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @matches.empty? %>
      <p class="text-gray-500 text-sm text-center py-8">No matches synced yet.</p>
    <% end %>
  </div>
</div>
