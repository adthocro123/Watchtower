<% content_for(:title) { "#{@event.name} - Watchtower" } %>

<div class="mb-6">
  <div class="flex items-center gap-2 mb-4">
    <%= link_to events_path, class: "back-link", "aria-label": "Back to events" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white"><%= @event.name %></h1>
  </div>

  <%# Event Info Card %>
  <div class="scout-card p-5 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Dates</span>
        <p class="text-sm text-white mt-1"><%= @event.start_date&.strftime("%B %d") %> - <%= @event.end_date&.strftime("%B %d, %Y") %></p>
      </div>
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Location</span>
        <p class="text-sm text-white mt-1"><%= [@event.city, @event.state_prov, @event.country].compact.join(", ").presence || "N/A" %></p>
      </div>
      <div>
        <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">TBA Key</span>
        <p class="text-sm text-gray-300 font-mono mt-1"><%= @event.tba_key %></p>
      </div>
    </div>

    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-800">
      <% if current_event&.id != @event.id %>
        <%= button_to "Select Event", select_event_path(@event), method: :post, class: "btn-primary text-sm" %>
      <% else %>
        <span class="badge-orange text-sm py-1.5 px-3">Currently Active</span>
      <% end %>
      <% if current_user.admin? %>
        <%= button_to "Sync from TBA", sync_event_path(@event), method: :post, class: "inline-flex items-center justify-center px-4 py-2 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white text-sm font-medium rounded-lg transition-all duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950", form: { data: { controller: "offline-guard", action: "submit->offline-guard#check" } } %>
        <%= link_to "Edit", edit_event_path(@event), class: "btn-secondary text-sm" %>
        <%= button_to "Delete", event_path(@event), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this event? All associated matches, scouting entries, and other data will be permanently removed." }, class: "btn-danger text-sm", form: { data: { controller: "offline-guard", action: "submit->offline-guard#check" } } %>
      <% end %>
    </div>

    <%# Cache for offline (auto-prefetches on load + manual button) %>
    <div class="mt-4 pt-4 border-t border-gray-800" data-controller="prefetch" data-prefetch-event-id-value="<%= @event.id %>" data-prefetch-manifest-url-value="<%= offline_manifest_event_path(@event) %>">
      <button data-action="prefetch#cache"
              data-prefetch-target="cacheButton"
              class="flex items-center justify-center gap-2 w-full px-3 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg transition group text-sm text-gray-300 hover:text-white disabled:opacity-50 disabled:cursor-not-allowed">
        <svg class="w-4 h-4 text-cyan-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span>Cache for Offline</span>
      </button>
      <div data-prefetch-target="progressContainer" class="hidden mt-2">
        <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
          <div data-prefetch-target="progressBar"
               class="bg-cyan-500 h-1.5 rounded-full transition-all duration-300"
               style="width: 0%"></div>
        </div>
        <span data-prefetch-target="progressText" class="text-[10px] text-gray-500 mt-1 block text-center"></span>
      </div>
    </div>
  </div>

  <%# Teams at Event %>
  <div class="scout-card overflow-hidden mb-6">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
      <h2 class="text-lg font-semibold text-white">Teams (<%= @teams.count %>)</h2>
    </div>
    <div class="p-4 sm:p-6">
      <% if @teams.any? %>
        <div class="flex flex-wrap gap-2">
          <% @teams.each do |team| %>
            <%= link_to team_path(team), class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:border-gray-600 rounded-lg text-sm transition-all duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500" do %>
              <span class="font-bold text-orange-400 font-mono"><%= team.team_number %></span>
              <% if team.nickname.present? %>
                <span class="text-gray-400 text-xs truncate max-w-28"><%= team.nickname %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6">
          <svg class="w-10 h-10 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="text-gray-500 text-sm">No teams synced yet. Sync from TBA to import teams.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Matches %>
  <div class="scout-card overflow-hidden">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
      <h2 class="text-lg font-semibold text-white">Matches (<%= @matches.count %>)</h2>
    </div>
    <% if @matches.any? %>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr class="border-b border-gray-800">
              <th scope="col" class="text-left">Match</th>
              <th scope="col" class="text-left">Time</th>
              <th scope="col" class="text-left">Red Alliance</th>
              <th scope="col" class="text-left">Blue Alliance</th>
            </tr>
          </thead>
          <tbody>
            <% @matches.each do |match| %>
              <tr>
                <td class="font-semibold text-white"><%= match.display_name %></td>
                <td class="text-gray-400 text-xs"><%= match.scheduled_time&.strftime("%b %d %l:%M %p") || "TBD" %></td>
                <td>
                  <div class="flex gap-1.5">
                    <% match.match_alliances.select { |ma| ma.alliance_color == "red" }.sort_by(&:station).each do |ma| %>
                      <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-red-500/20 text-red-400 border border-red-500/20"><%= ma.frc_team.team_number %></span>
                    <% end %>
                  </div>
                </td>
                <td>
                  <div class="flex gap-1.5">
                    <% match.match_alliances.select { |ma| ma.alliance_color == "blue" }.sort_by(&:station).each do |ma| %>
                      <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-blue-500/20 text-blue-400 border border-blue-500/20"><%= ma.frc_team.team_number %></span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="w-10 h-10 text-gray-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500 text-sm">No matches synced yet. Sync from TBA to import match schedule.</p>
      </div>
    <% end %>
  </div>
</div>
