<% content_for(:title) { "Edit #{@organization.name} - Lighthouse" } %>

<div class="max-w-md mx-auto mt-8">
  <h1 class="text-2xl font-bold text-white mb-6">Edit Organization</h1>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 sm:p-6">
    <%= form_with(model: @organization, class: "space-y-4", data: { controller: "offline-guard", action: "submit->offline-guard#check" }) do |f| %>
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :name, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition" %>
      </div>
      <div>
        <%= f.label :team_number, class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.number_field :team_number, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition" %>
      </div>
      <%= f.submit "Update Organization", class: "w-full py-3 bg-orange-600 hover:bg-orange-500 text-white font-medium rounded-lg transition cursor-pointer" %>
    <% end %>
  </div>
</div>
