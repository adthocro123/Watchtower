<% content_for(:title) { "#{@organization.name} - Lighthouse" } %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white"><%= @organization.name %></h1>
      <% if @organization.team_number %>
        <p class="text-sm text-gray-400 mt-1">Team <%= @organization.team_number %></p>
      <% end %>
    </div>
    <% if current_user.admin_of?(@organization) %>
      <%= link_to "Edit", edit_organization_path(@organization), class: "px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg transition" %>
    <% end %>
  </div>

  <%# Members %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6" data-controller="bulk-select" data-bulk-select-organization-id-value="<%= @organization.id %>">

    <div class="px-4 sm:px-6 py-4 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-white">Members (<%= @members.size %>)</h2>

      <% if @can_manage %>
        <%# Bulk actions bar - hidden until members are selected %>
        <div class="flex items-center gap-2" data-bulk-select-target="bulkActions" style="display: none;">
          <span class="text-xs text-gray-400 mr-1" data-bulk-select-target="selectedCount">0 selected</span>

          <%# Bulk role change %>
          <%= form_with url: bulk_update_organization_memberships_path(@organization), method: :post, class: "flex items-center gap-1", data: { turbo: false, bulk_select_target: "bulkUpdateForm" } do %>
            <div data-bulk-select-target="bulkUpdateIds"></div>
            <%= select_tag :role, options_for_select([["Scout", "scout"], ["Analyst", "analyst"], ["Lead", "lead"], ["Admin", "admin"]]), class: "bg-gray-800 border border-gray-700 rounded-lg px-2 py-1 text-white text-xs focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition" %>
            <button type="submit" class="px-2 py-1 bg-blue-600 hover:bg-blue-500 text-white text-xs font-medium rounded-lg transition">
              Change Role
            </button>
          <% end %>

          <%# Bulk remove %>
          <%= form_with url: bulk_destroy_organization_memberships_path(@organization), method: :post, data: { turbo: false, turbo_confirm: "Remove all selected members?", bulk_select_target: "bulkDestroyForm" } do %>
            <div data-bulk-select-target="bulkDestroyIds"></div>
            <button type="submit" class="px-2 py-1 bg-red-600 hover:bg-red-500 text-white text-xs font-medium rounded-lg transition">
              Remove Selected
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="divide-y divide-gray-800/50">
      <% @members.each do |membership| %>
        <% is_owner = membership.owner? %>
        <div class="flex items-center justify-between px-4 sm:px-6 py-3">
          <div class="flex items-center gap-3">
            <%# Checkbox for bulk selection (admin+ only, not for owner) %>
            <% if @can_manage && !is_owner %>
              <input type="checkbox"
                     value="<%= membership.id %>"
                     data-bulk-select-target="checkbox"
                     data-action="change->bulk-select#toggle"
                     class="w-4 h-4 rounded border-gray-600 bg-gray-800 text-orange-500 focus:ring-orange-500 focus:ring-offset-0 cursor-pointer">
            <% elsif @can_manage %>
              <div class="w-4 h-4"></div>
            <% end %>

            <div class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center">
              <span class="text-sm font-bold text-gray-400"><%= membership.user.first_name[0] %><%= membership.user.last_name[0] %></span>
            </div>
            <div>
              <p class="text-sm font-medium text-white">
                <%= membership.user.full_name %>
                <% if is_owner %>
                  <span class="text-xs text-purple-400 ml-1">(Creator)</span>
                <% end %>
              </p>
              <p class="text-xs text-gray-500"><%= membership.user.email %></p>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <% if @can_manage && !is_owner %>
              <%# Inline role dropdown %>
              <%= form_with model: membership, url: organization_membership_path(@organization, membership), method: :patch, data: { turbo: false } do |f| %>
                <%= f.select :role, [["Scout", "scout"], ["Analyst", "analyst"], ["Lead", "lead"], ["Admin", "admin"]], { selected: membership.role }, class: "bg-gray-800 border border-gray-700 rounded-lg px-2 py-1 text-white text-xs focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition", onchange: "if(confirm('Change this member\\'s role?')) this.form.submit(); else this.value='#{membership.role}';" %>
              <% end %>

              <%# Remove button %>
              <%= button_to organization_membership_path(@organization, membership), method: :delete, data: { turbo_confirm: "Remove #{membership.user.full_name} from the organization?" }, class: "p-1.5 text-gray-500 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              <% end %>
            <% else %>
              <%# Read-only role badge %>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full
                <%= case membership.role
                    when 'owner' then 'bg-purple-500/20 text-purple-400 border border-purple-500/30'
                    when 'admin' then 'bg-red-500/20 text-red-400 border border-red-500/30'
                    when 'lead' then 'bg-amber-500/20 text-amber-400 border border-amber-500/30'
                    when 'analyst' then 'bg-blue-500/20 text-blue-400 border border-blue-500/30'
                    else 'bg-gray-500/20 text-gray-400 border border-gray-500/30'
                    end %>">
                <%= membership.role.capitalize %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Invite form %>
  <% if current_user.lead_of?(@organization) %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <h3 class="text-sm font-semibold text-white mb-4">Invite Member</h3>
      <%= form_with url: invite_organization_path(@organization), method: :post, class: "flex flex-col sm:flex-row gap-3", data: { controller: "offline-guard", action: "submit->offline-guard#check" } do |f| %>
        <div class="flex-1">
          <%= email_field_tag :email, nil, class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition", placeholder: "user@example.com", required: true %>
        </div>
        <div>
          <%= select_tag :role, options_for_select([["Scout", "scout"], ["Analyst", "analyst"], ["Lead", "lead"], ["Admin", "admin"]]), class: "w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition" %>
        </div>
        <button type="submit" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-500 text-white text-sm font-medium rounded-lg transition whitespace-nowrap">Invite</button>
      <% end %>
    </div>
  <% end %>
</div>
