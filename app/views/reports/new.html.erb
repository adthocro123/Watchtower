<% content_for(:title) { "New Report - Lighthouse" } %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to reports_path, class: "text-gray-500 hover:text-gray-300 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-white">New Report</h1>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 sm:p-6">
    <%= render "form", report: @report %>
  </div>
</div>
