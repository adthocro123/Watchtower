<% content_for(:title) { "Pit Scouting - Lighthouse" } %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Pit Scouting</h1>
    <p class="text-sm text-gray-400 mt-1"><%= @scouted_team_ids.size %> of <%= @teams.count %> teams scouted at <%= current_event.name %></p>
  </div>
  <%= link_to new_pit_scouting_entry_path, class: "flex items-center gap-2 px-4 py-2 bg-orange-600 hover:bg-orange-500 text-white text-sm font-medium rounded-lg transition" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    <span class="hidden sm:inline">Pit Scout</span>
  <% end %>
</div>

<% # Progress bar %>
<div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6">
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm text-gray-400">Scouting Progress</span>
    <% pct = @teams.any? ? (@scouted_team_ids.size.to_f / @teams.count * 100).round(0) : 0 %>
    <span class="text-sm font-bold text-orange-400"><%= pct %>%</span>
  </div>
  <div class="w-full h-3 bg-gray-800 rounded-full overflow-hidden">
    <div class="h-full bg-orange-500 rounded-full transition-all" style="width: <%= pct %>%"></div>
  </div>
</div>

<% # Team grid showing scouted/unscouted status %>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
  <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
    <h2 class="text-lg font-semibold text-white">Teams</h2>
  </div>
  <div class="p-4 sm:p-6">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2">
      <% @teams.each do |team| %>
        <% scouted = @scouted_team_ids.include?(team.id) %>
        <% entry = @pit_scouting_entries.find { |e| e.frc_team_id == team.id } if scouted %>
        <% if scouted && entry %>
          <%= link_to pit_scouting_entry_path(entry), class: "bg-orange-500/10 border border-orange-500/30 rounded-lg p-3 text-center hover:bg-orange-500/20 transition" do %>
            <p class="font-bold text-orange-400"><%= team.team_number %></p>
            <p class="text-xs text-orange-400/60 mt-0.5">Scouted</p>
          <% end %>
        <% else %>
          <%= link_to new_pit_scouting_entry_path(frc_team_id: team.id), class: "bg-gray-800 border border-gray-700 rounded-lg p-3 text-center hover:bg-gray-700 transition" do %>
            <p class="font-bold text-gray-400"><%= team.team_number %></p>
            <p class="text-xs text-gray-600 mt-0.5">Not scouted</p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% # Recent pit scouting entries %>
<% if @pit_scouting_entries.any? %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mt-6">
    <div class="px-4 sm:px-6 py-4 border-b border-gray-800">
      <h2 class="text-lg font-semibold text-white">Recent Entries</h2>
    </div>
    <div class="divide-y divide-gray-800/50">
      <% @pit_scouting_entries.limit(20).each do |entry| %>
        <%= link_to pit_scouting_entry_path(entry), class: "flex items-center justify-between px-4 sm:px-6 py-3 hover:bg-gray-800/50 transition" do %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center">
              <span class="text-sm font-bold text-orange-400"><%= entry.frc_team.team_number %></span>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Team <%= entry.frc_team.team_number %> <span class="text-gray-500"><%= entry.frc_team.nickname %></span></p>
              <p class="text-xs text-gray-500"><%= entry.user.full_name %> &middot; <%= time_ago_in_words(entry.updated_at) %> ago</p>
            </div>
          </div>
          <div class="text-right">
            <span class="text-xs text-gray-500"><%= entry.drivetrain %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
